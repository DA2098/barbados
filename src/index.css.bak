@import "tailwindcss";

/* ================================================
   ðŸ”¥ BARBADOS ELITE - Sistema de DiseÃ±o Ultra Premium
   âœ¨ Animaciones Cascada | Transiciones Fluidas
   ðŸ“± 100% Responsive | Performance Optimizado
   ================================================ */

/* ==========================================
   ðŸŽ¨ VARIABLES DE DISEÃ‘O PREMIUM
   ========================================== */
:root {
  /* ðŸŽ¨ NUEVA PALETA - Cyan ElÃ©ctrico + Violeta */
  --gold: #00d4ff;
  --gold-2: #00b8e6;
  --gold-3: #0099cc;
  --gold-glow: rgba(0, 212, 255, 0.6);
  --gold-subtle: rgba(0, 212, 255, 0.15);
  
  /* Colores Secundarios Vibrantes */
  --neon-pink: #ff006e;
  --neon-purple: #8338ec;
  --neon-green: #00f5d4;
  --neon-orange: #ff9500;
  --neon-yellow: #ffbe0b;
  
  /* Fondos Oscuros con Tinte Violeta */
  --bg-primary: #0a0a12;
  --bg-secondary: #12121f;
  --bg-tertiary: #1a1a2e;
  --bg-card: rgba(18, 18, 35, 0.95);
  --bg-card-hover: rgba(26, 26, 50, 0.98);
  
  /* Textos */
  --text-primary: #ffffff;
  --text-secondary: #b4b4d0;
  --text-muted: rgba(180, 180, 208, 0.7);
  --muted: #b4b4d0;
  
  /* Acentos */
  --accent-red: #ff006e;
  --accent-blue: #00d4ff;
  --accent-green: #00f5d4;
  --accent-purple: #8338ec;
  
  /* Sombras con Glow */
  --shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
  --shadow-gold: 0 20px 60px rgba(0, 212, 255, 0.3);
  --shadow-card: 0 40px 80px rgba(0, 0, 0, 0.5);
  --shadow-neon: 0 0 40px rgba(0, 212, 255, 0.4), 0 0 80px rgba(131, 56, 236, 0.2);
  
  /* Bordes */
  --border-subtle: rgba(255, 255, 255, 0.08);
  --border-gold: rgba(0, 212, 255, 0.4);
  
  /* Gradientes */
  --gradient-main: linear-gradient(135deg, #00d4ff 0%, #8338ec 50%, #ff006e 100%);
  --gradient-card: linear-gradient(145deg, rgba(0, 212, 255, 0.1), rgba(131, 56, 236, 0.05));
  --gradient-glow: radial-gradient(ellipse at center, rgba(0, 212, 255, 0.15), transparent 70%);
  
  /* Timing Functions */
  --ease-bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);
  --ease-smooth: cubic-bezier(0.4, 0, 0.2, 1);
  --ease-spring: cubic-bezier(0.175, 0.885, 0.32, 1.275);
  --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-elastic: cubic-bezier(0.68, -0.6, 0.32, 1.6);
}

/* ==========================================
   ðŸŒŠ ANIMACIONES CASCADA PREMIUM
   ========================================== */

/* FlotaciÃ³n Suave */
@keyframes float {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  25% { transform: translateY(-8px) rotate(1deg); }
  50% { transform: translateY(-15px) rotate(0deg); }
  75% { transform: translateY(-8px) rotate(-1deg); }
}

@keyframes float-delayed {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-20px); }
}

/* Brillo Pulsante */
@keyframes glow-pulse {
  0%, 100% { 
    box-shadow: 0 0 20px var(--gold-glow), 0 0 40px rgba(0, 212, 255, 0.2);
    filter: brightness(1);
  }
  50% { 
    box-shadow: 0 0 40px var(--gold-glow), 0 0 80px rgba(0, 212, 255, 0.4);
    filter: brightness(1.1);
  }
}

/* Entrada Deslizante */
@keyframes slide-in {
  from { 
    opacity: 0; 
    transform: translateY(40px) scale(0.95);
    filter: blur(10px);
  }
  to { 
    opacity: 1; 
    transform: translateY(0) scale(1);
    filter: blur(0);
  }
}

@keyframes slide-in-left {
  from { 
    opacity: 0; 
    transform: translateX(-60px);
  }
  to { 
    opacity: 1; 
    transform: translateX(0);
  }
}

@keyframes slide-in-right {
  from { 
    opacity: 0; 
    transform: translateX(60px);
  }
  to { 
    opacity: 1; 
    transform: translateX(0);
  }
}

/* Escalado con Rebote */
@keyframes scale-in {
  0% { 
    opacity: 0; 
    transform: scale(0.5);
  }
  50% { 
    transform: scale(1.05);
  }
  100% { 
    opacity: 1; 
    transform: scale(1);
  }
}

@keyframes scale-bounce {
  0% { transform: scale(1); }
  25% { transform: scale(0.95); }
  50% { transform: scale(1.08); }
  75% { transform: scale(0.98); }
  100% { transform: scale(1); }
}

/* Efecto Shimmer/Brillo */
@keyframes shimmer {
  0% { background-position: -1000px 0; }
  100% { background-position: 1000px 0; }
}

@keyframes shimmer-fast {
  0% { background-position: -500px 0; }
  100% { background-position: 500px 0; }
}

/* Gradiente Animado */
@keyframes gradient-shift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

@keyframes gradient-flow {
  0% { background-position: 0% 0%; }
  50% { background-position: 100% 100%; }
  100% { background-position: 0% 0%; }
}

/* RotaciÃ³n Suave */
@keyframes spin-slow {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes spin-reverse {
  from { transform: rotate(360deg); }
  to { transform: rotate(0deg); }
}

/* Parpadeo Elegante */
@keyframes blink-soft {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* Onda de Pulso */
@keyframes ripple {
  0% {
    transform: scale(0.8);
    opacity: 1;
  }
  100% {
    transform: scale(2.5);
    opacity: 0;
  }
}

@keyframes ripple-infinite {
  0% {
    box-shadow: 0 0 0 0 var(--gold-glow);
  }
  70% {
    box-shadow: 0 0 0 20px transparent;
  }
  100% {
    box-shadow: 0 0 0 0 transparent;
  }
}

/* Efecto Typewriter */
@keyframes typewriter {
  from { width: 0; }
  to { width: 100%; }
}

@keyframes cursor-blink {
  0%, 50% { border-color: var(--gold); }
  51%, 100% { border-color: transparent; }
}

/* Morphing de Formas */
@keyframes morph {
  0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
  25% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
  50% { border-radius: 50% 60% 30% 60% / 30% 70% 50% 60%; }
  75% { border-radius: 60% 40% 60% 30% / 70% 30% 50% 40%; }
}

/* LÃ­nea de Escaneo */
@keyframes scan-line {
  0% { transform: translateY(-100%); }
  100% { transform: translateY(100vh); }
}

/* Sacudida Suave */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
  20%, 40%, 60%, 80% { transform: translateX(5px); }
}

/* Rebote */
@keyframes bounce {
  0%, 20%, 53%, 100% { 
    animation-timing-function: cubic-bezier(0.215, 0.61, 0.355, 1);
    transform: translate3d(0, 0, 0); 
  }
  40%, 43% { 
    animation-timing-function: cubic-bezier(0.755, 0.05, 0.855, 0.06);
    transform: translate3d(0, -30px, 0) scaleY(1.1); 
  }
  70% { 
    animation-timing-function: cubic-bezier(0.755, 0.05, 0.855, 0.06);
    transform: translate3d(0, -15px, 0) scaleY(1.05); 
  }
  80% { 
    transform: translate3d(0, 0, 0) scaleY(0.95); 
  }
  90% { 
    transform: translate3d(0, -4px, 0) scaleY(1.02); 
  }
}

/* Pulso MicrÃ³fono */
@keyframes mic-pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.3); opacity: 0.7; }
}

@keyframes recording-glow {
  0%, 100% { box-shadow: 0 0 8px rgba(251, 113, 133, 0.5); }
  50% { box-shadow: 0 0 25px rgba(251, 113, 133, 0.9); }
}

/* Cascada de ApariciÃ³n */
@keyframes cascade-in {
  0% {
    opacity: 0;
    transform: translateY(50px) rotateX(-10deg);
    filter: blur(10px);
  }
  100% {
    opacity: 1;
    transform: translateY(0) rotateX(0deg);
    filter: blur(0);
  }
}

/* Efecto Aurora/Northern Lights */
@keyframes aurora {
  0%, 100% {
    background-position: 0% 50%;
    filter: hue-rotate(0deg);
  }
  50% {
    background-position: 100% 50%;
    filter: hue-rotate(30deg);
  }
}

/* Latido */
@keyframes heartbeat {
  0% { transform: scale(1); }
  14% { transform: scale(1.15); }
  28% { transform: scale(1); }
  42% { transform: scale(1.15); }
  70% { transform: scale(1); }
}

/* Desenfocar y Enfocar */
@keyframes focus-in {
  0% {
    filter: blur(12px);
    opacity: 0;
  }
  100% {
    filter: blur(0);
    opacity: 1;
  }
}

/* Olas de Fondo */
@keyframes wave {
  0% { transform: translateX(0) translateZ(0) scaleY(1); }
  50% { transform: translateX(-25%) translateZ(0) scaleY(0.8); }
  100% { transform: translateX(-50%) translateZ(0) scaleY(1); }
}

/* PartÃ­culas Flotantes */
@keyframes particle-float {
  0%, 100% {
    transform: translate(0, 0) rotate(0deg);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    transform: translate(var(--move-x, 100px), var(--move-y, -200px)) rotate(720deg);
    opacity: 0;
  }
}

/* Efecto de Texto 3D */
@keyframes text-shadow-pop {
  0% {
    text-shadow: 0 0 var(--gold), 0 0 var(--gold);
  }
  100% {
    text-shadow: 
      1px 1px var(--gold-2),
      2px 2px var(--gold-3),
      3px 3px rgba(0, 212, 255, 0.6),
      4px 4px rgba(0, 212, 255, 0.4),
      5px 5px rgba(0, 212, 255, 0.2);
  }
}

/* Efecto de NeÃ³n */
@keyframes neon-flicker {
  0%, 19%, 21%, 23%, 25%, 54%, 56%, 100% {
    text-shadow:
      0 0 4px #fff,
      0 0 11px #fff,
      0 0 19px #fff,
      0 0 40px var(--gold),
      0 0 80px var(--gold),
      0 0 90px var(--gold),
      0 0 100px var(--gold),
      0 0 150px var(--gold);
  }
  20%, 24%, 55% {
    text-shadow: none;
  }
}

/* ==========================================
   ðŸ’ˆ ESTILOS GLOBALES ULTRA PREMIUM
   ========================================== */

/* Reset y Base Optimizada */
*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
  font-size: 16px;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
}

body {
  font-family: 'Inter', 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background: var(--bg-primary);
  color: var(--text-primary);
  line-height: 1.6;
  overflow-x: hidden;
  min-height: 100vh;
  position: relative;
}

/* Fondo Animado Global - Efecto Aurora Cyberpunk */
body::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(ellipse 100% 60% at 10% -30%, rgba(0, 212, 255, 0.2) 0%, transparent 50%),
    radial-gradient(ellipse 80% 50% at 90% 110%, rgba(131, 56, 236, 0.18) 0%, transparent 50%),
    radial-gradient(ellipse 60% 40% at 50% 50%, rgba(255, 0, 110, 0.08) 0%, transparent 60%),
    radial-gradient(circle at 30% 70%, rgba(0, 245, 212, 0.1) 0%, transparent 40%);
  pointer-events: none;
  z-index: -1;
  animation: aurora-cyber 20s ease-in-out infinite;
  background-size: 200% 200%;
}

@keyframes aurora-cyber {
  0%, 100% { 
    background-position: 0% 50%;
    filter: hue-rotate(0deg);
  }
  25% { 
    background-position: 50% 0%;
    filter: hue-rotate(10deg);
  }
  50% { 
    background-position: 100% 50%;
    filter: hue-rotate(0deg);
  }
  75% { 
    background-position: 50% 100%;
    filter: hue-rotate(-10deg);
  }
}

/* Rejilla Cyberpunk Animada (fondo decorativo) */
body::after {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    linear-gradient(rgba(0, 212, 255, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 212, 255, 0.03) 1px, transparent 1px),
    repeating-linear-gradient(
      45deg,
      transparent,
      transparent 150px,
      rgba(131, 56, 236, 0.02) 150px,
      rgba(131, 56, 236, 0.02) 152px
    );
  background-size: 60px 60px, 60px 60px, auto;
  pointer-events: none;
  z-index: -1;
  animation: grid-move 30s linear infinite;
}

@keyframes grid-move {
  0% { background-position: 0 0, 0 0, 0 0; }
  100% { background-position: 60px 60px, 60px 60px, 200px 0; }
}

/* ==========================================
   ðŸŽ­ UTILIDADES DE ANIMACIÃ“N CASCADA
   ========================================== */

/* Delays para efecto cascada */
.cascade-1 { animation-delay: 0.1s; }
.cascade-2 { animation-delay: 0.2s; }
.cascade-3 { animation-delay: 0.3s; }
.cascade-4 { animation-delay: 0.4s; }
.cascade-5 { animation-delay: 0.5s; }
.cascade-6 { animation-delay: 0.6s; }
.cascade-7 { animation-delay: 0.7s; }
.cascade-8 { animation-delay: 0.8s; }
.cascade-9 { animation-delay: 0.9s; }
.cascade-10 { animation-delay: 1s; }

/* Clases de AnimaciÃ³n Reutilizables */
.animate-float { animation: float 6s ease-in-out infinite; }
.animate-glow { animation: glow-pulse 3s ease-in-out infinite; }
.animate-slide-in { animation: slide-in 0.8s var(--ease-out-expo) forwards; }
.animate-scale-in { animation: scale-in 0.6s var(--ease-spring) forwards; }
.animate-cascade { animation: cascade-in 0.8s var(--ease-out-expo) forwards; opacity: 0; }
.animate-shimmer { animation: shimmer 2.5s linear infinite; }
.animate-heartbeat { animation: heartbeat 1.5s ease-in-out infinite; }
.animate-bounce { animation: bounce 2s ease infinite; }
.animate-morph { animation: morph 8s ease-in-out infinite; }
.animate-ripple { animation: ripple-infinite 1.5s ease-out infinite; }

/* Hover Animations */
.hover-lift { transition: transform 0.4s var(--ease-spring), box-shadow 0.4s ease; }
.hover-lift:hover { transform: translateY(-8px) scale(1.02); box-shadow: var(--shadow-gold); }

.hover-glow { transition: box-shadow 0.4s ease, border-color 0.4s ease; }
.hover-glow:hover { box-shadow: 0 0 30px var(--gold-glow); border-color: var(--gold) !important; }

.hover-scale { transition: transform 0.3s var(--ease-spring); }
.hover-scale:hover { transform: scale(1.05); }

.hover-rotate { transition: transform 0.5s var(--ease-bounce); }
.hover-rotate:hover { transform: rotate(5deg) scale(1.05); }

/* ==========================================
   ðŸƒ TARJETAS GLASSMORPHISM PREMIUM
   ========================================== */
.glass-card {
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.1) 0%,
    rgba(255, 255, 255, 0.05) 100%
  );
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 24px;
  box-shadow: 
    0 8px 32px rgba(0, 0, 0, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.1),
    inset 0 -1px 0 rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
  transition: all 0.4s var(--ease-smooth);
}

.glass-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.1),
    transparent
  );
  transition: left 0.6s ease;
}

.glass-card:hover::before {
  left: 100%;
}

.glass-card:hover {
  transform: translateY(-5px);
  box-shadow: 
    0 20px 60px rgba(0, 0, 0, 0.4),
    0 0 40px rgba(0, 212, 255, 0.1),
    inset 0 1px 0 rgba(255, 255, 255, 0.15);
  border-color: var(--border-gold);
}

/* Tarjeta con Borde Dorado */
.gold-card {
  background: var(--bg-card);
  border: 2px solid transparent;
  border-radius: 20px;
  position: relative;
  padding: 2rem;
  overflow: hidden;
  transition: all 0.5s var(--ease-smooth);
}

.gold-card::before {
  content: '';
  position: absolute;
  inset: -2px;
  background: linear-gradient(135deg, var(--gold), var(--gold-2), var(--gold-3), var(--gold));
  background-size: 300% 300%;
  border-radius: 22px;
  z-index: -1;
  animation: gradient-flow 5s ease infinite;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.gold-card:hover::before {
  opacity: 1;
}

.gold-card:hover {
  transform: translateY(-8px) scale(1.02);
  box-shadow: 0 30px 80px rgba(0, 212, 255, 0.3);
}

/* ==========================================
   ðŸ”˜ BOTONES ULTRA PREMIUM
   ========================================== */
.btn-premium {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  padding: 1rem 2rem;
  font-size: 1rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border: none;
  border-radius: 50px;
  cursor: pointer;
  overflow: hidden;
  transition: all 0.4s var(--ease-spring);
  z-index: 1;
}

.btn-premium--gold {
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold-2) 100%);
  color: #0a1a1f;
  box-shadow: 
    0 10px 40px rgba(0, 212, 255, 0.4),
    inset 0 1px 0 rgba(255, 255, 255, 0.3);
}

.btn-premium--gold::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 200%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.4) 50%,
    transparent 100%
  );
  transform: skewX(-20deg);
  transition: left 0.7s ease;
}

.btn-premium--gold:hover {
  transform: translateY(-4px) scale(1.05);
  box-shadow: 
    0 20px 60px rgba(0, 212, 255, 0.5),
    0 0 40px rgba(0, 212, 255, 0.3);
}

.btn-premium--gold:hover::before {
  left: 100%;
}

.btn-premium--gold:active {
  transform: translateY(-2px) scale(1.02);
}

.btn-premium--outline {
  background: transparent;
  color: var(--text-primary);
  border: 2px solid var(--border-gold);
  box-shadow: none;
}

.btn-premium--outline:hover {
  background: rgba(0, 212, 255, 0.1);
  border-color: var(--gold);
  box-shadow: 0 0 30px rgba(0, 212, 255, 0.2);
  transform: translateY(-3px);
}

.btn-premium--ghost {
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-primary);
  border: 1px solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
}

.btn-premium--ghost:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.2);
  transform: translateY(-3px);
}

/* BotÃ³n con Efecto de Ondas */
.btn-ripple {
  position: relative;
  overflow: hidden;
}

.btn-ripple::after {
  content: '';
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  pointer-events: none;
  background-image: radial-gradient(circle, rgba(255, 255, 255, 0.3) 10%, transparent 10.01%);
  background-repeat: no-repeat;
  background-position: 50%;
  transform: scale(10, 10);
  opacity: 0;
  transition: transform 0.5s, opacity 1s;
}

.btn-ripple:active::after {
  transform: scale(0, 0);
  opacity: 0.3;
  transition: 0s;
}

/* ==========================================
   ðŸ“ INPUTS PREMIUM
   ========================================== */
.input-premium {
  width: 100%;
  padding: 1rem 1.5rem;
  font-size: 1rem;
  color: var(--text-primary);
  background: rgba(255, 255, 255, 0.05);
  border: 2px solid var(--border-subtle);
  border-radius: 16px;
  outline: none;
  transition: all 0.4s var(--ease-smooth);
  position: relative;
}

.input-premium::placeholder {
  color: var(--text-muted);
  transition: all 0.3s ease;
}

.input-premium:focus {
  border-color: var(--gold);
  background: rgba(0, 212, 255, 0.05);
  box-shadow: 
    0 0 0 4px rgba(0, 212, 255, 0.15),
    0 10px 40px rgba(0, 0, 0, 0.2);
}

.input-premium:focus::placeholder {
  opacity: 0.5;
  transform: translateX(10px);
}

/* Input con Icono */
.input-wrapper {
  position: relative;
}

.input-wrapper .input-icon {
  position: absolute;
  left: 1.25rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-muted);
  font-size: 1.2rem;
  transition: color 0.3s ease;
  pointer-events: none;
}

.input-wrapper .input-premium {
  padding-left: 3.5rem;
}

.input-wrapper:focus-within .input-icon {
  color: var(--gold);
}

/* ==========================================
   ðŸ† BADGES Y TAGS ANIMADOS
   ========================================== */
.badge-premium {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 1rem;
  font-size: 0.85rem;
  font-weight: 600;
  border-radius: 50px;
  transition: all 0.3s var(--ease-smooth);
}

.badge-premium--gold {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.2), rgba(0, 212, 255, 0.1));
  color: var(--gold);
  border: 1px solid rgba(0, 212, 255, 0.3);
}

.badge-premium--gold:hover {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.3), rgba(0, 212, 255, 0.2));
  transform: scale(1.05);
  box-shadow: 0 5px 20px rgba(0, 212, 255, 0.2);
}

.badge-premium--success {
  background: linear-gradient(135deg, rgba(74, 222, 128, 0.2), rgba(74, 222, 128, 0.1));
  color: var(--accent-green);
  border: 1px solid rgba(74, 222, 128, 0.3);
}

.badge-premium--pulse {
  animation: glow-pulse 2s ease-in-out infinite;
}

/* ==========================================
   ðŸ“¦ SECCIONES CON PARALLAX
   ========================================== */
.section-parallax {
  position: relative;
  overflow: hidden;
}

.section-parallax::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(ellipse at center, rgba(0, 212, 255, 0.05) 0%, transparent 60%);
  transform: rotate(45deg);
  animation: float 20s ease-in-out infinite;
}

/* ==========================================
   ðŸŽ¨ TEXTO CON GRADIENTE ANIMADO
   ========================================== */
.text-gradient {
  background: linear-gradient(135deg, #fff 0%, var(--gold) 25%, #fff 50%, var(--gold) 75%, #fff 100%);
  background-size: 300% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer 4s linear infinite;
}

.text-glow {
  text-shadow: 
    0 0 10px var(--gold-glow),
    0 0 20px rgba(0, 212, 255, 0.3),
    0 0 40px rgba(0, 212, 255, 0.1);
}

.text-neon {
  animation: neon-flicker 3s ease-in-out infinite;
}

/* ==========================================
   ðŸ–¼ï¸ IMÃGENES CON EFECTOS
   ========================================== */
.img-premium {
  border-radius: 20px;
  overflow: hidden;
  position: relative;
  transition: all 0.5s var(--ease-smooth);
}

.img-premium img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.7s var(--ease-smooth);
}

.img-premium:hover img {
  transform: scale(1.1);
}

.img-premium::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(7, 16, 28, 0.8) 0%, transparent 50%);
  opacity: 0;
  transition: opacity 0.4s ease;
}

.img-premium:hover::after {
  opacity: 1;
}

/* ==========================================
   ðŸ“± RESPONSIVE UTILITIES
   ========================================== */

/* Container Responsive */
.container-fluid {
  width: 100%;
  padding: 0 1rem;
  margin: 0 auto;
}

@media (min-width: 640px) {
  .container-fluid { padding: 0 1.5rem; }
}

@media (min-width: 768px) {
  .container-fluid { padding: 0 2rem; }
}

@media (min-width: 1024px) {
  .container-fluid { padding: 0 3rem; }
}

@media (min-width: 1280px) {
  .container-fluid { padding: 0 4rem; max-width: 1440px; }
}

/* Grid Responsive */
.grid-responsive {
  display: grid;
  gap: 1.5rem;
  grid-template-columns: 1fr;
}

@media (min-width: 640px) {
  .grid-responsive { grid-template-columns: repeat(2, 1fr); }
}

@media (min-width: 1024px) {
  .grid-responsive { grid-template-columns: repeat(3, 1fr); gap: 2rem; }
}

@media (min-width: 1280px) {
  .grid-responsive { grid-template-columns: repeat(4, 1fr); }
}

/* Flexbox Responsive */
.flex-responsive {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

@media (min-width: 768px) {
  .flex-responsive { flex-direction: row; gap: 1.5rem; }
}

/* Hide/Show Responsive */
.hide-mobile { display: none !important; }
.show-mobile { display: block !important; }

@media (min-width: 768px) {
  .hide-mobile { display: block !important; }
  .show-mobile { display: none !important; }
}

.hide-tablet { display: block !important; }
@media (min-width: 768px) and (max-width: 1023px) {
  .hide-tablet { display: none !important; }
}

/* ==========================================
   ðŸŽª EFECTOS ESPECIALES BARBERÃA
   ========================================== */

/* Poste de Barbero Animado */
.barber-pole {
  width: 20px;
  height: 100px;
  background: repeating-linear-gradient(
    45deg,
    #fff 0px,
    #fff 10px,
    #e63946 10px,
    #e63946 20px,
    #fff 20px,
    #fff 30px,
    #1d3557 30px,
    #1d3557 40px
  );
  border-radius: 10px;
  animation: barber-spin 3s linear infinite;
  box-shadow: 0 5px 20px rgba(0, 0, 0, 0.3);
}

@keyframes barber-spin {
  from { background-position: 0 0; }
  to { background-position: 0 80px; }
}

/* Tijeras Animadas */
.scissors-icon {
  display: inline-block;
  transition: transform 0.3s var(--ease-bounce);
}

.scissors-icon:hover {
  transform: rotate(-20deg) scale(1.2);
  animation: shake 0.5s ease-in-out;
}

/* Estrellas de Rating */
.stars-rating {
  display: flex;
  gap: 0.25rem;
}

.star {
  color: var(--gold);
  font-size: 1.25rem;
  transition: transform 0.2s var(--ease-bounce);
}

.star:hover {
  transform: scale(1.3) rotate(15deg);
}

.star.filled {
  animation: heartbeat 1s ease-in-out infinite;
}

/* ==========================================
   ðŸŒ™ SCROLLBAR PERSONALIZADO
   ========================================== */
::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-track {
  background: var(--bg-secondary);
  border-radius: 10px;
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, var(--gold), var(--gold-2));
  border-radius: 10px;
  border: 2px solid var(--bg-secondary);
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(180deg, var(--gold-2), var(--gold-3));
}

/* Firefox */
* {
  scrollbar-width: thin;
  scrollbar-color: var(--gold) var(--bg-secondary);
}

/* ==========================================
   âœ¨ SELECTION STYLES
   ========================================== */
::selection {
  background: rgba(0, 212, 255, 0.3);
  color: var(--text-primary);
}

::-moz-selection {
  background: rgba(0, 212, 255, 0.3);
  color: var(--text-primary);
}

/* ==========================================
   ðŸŽ¯ FOCUS STATES ACCESIBLES
   ========================================== */
:focus-visible {
  outline: 2px solid var(--gold);
  outline-offset: 3px;
  border-radius: 4px;
}

button:focus-visible,
a:focus-visible,
input:focus-visible,
select:focus-visible,
textarea:focus-visible {
  outline: 2px solid var(--gold);
  outline-offset: 3px;
}

/* ==========================================
   ðŸ”„ TRANSICIONES GLOBALES SUAVES
   ========================================== */
a, button, input, select, textarea {
  transition: all 0.3s var(--ease-smooth);
}

/* ==========================================
   ðŸ“ ASPECT RATIOS
   ========================================== */
.aspect-square { aspect-ratio: 1 / 1; }
.aspect-video { aspect-ratio: 16 / 9; }
.aspect-portrait { aspect-ratio: 3 / 4; }
.aspect-wide { aspect-ratio: 21 / 9; }

/* ==========================================
   ðŸŽ­ ESTADOS DE CARGA
   ========================================== */

/* Skeleton Loading */
.skeleton {
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0.05) 25%,
    rgba(255, 255, 255, 0.1) 50%,
    rgba(255, 255, 255, 0.05) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8px;
}

.skeleton-text {
  height: 1em;
  margin: 0.5em 0;
}

.skeleton-title {
  height: 2em;
  width: 60%;
}

.skeleton-avatar {
  width: 50px;
  height: 50px;
  border-radius: 50%;
}

.skeleton-card {
  height: 200px;
}

/* Spinner Dorado */
.spinner-gold {
  width: 40px;
  height: 40px;
  border: 4px solid rgba(0, 212, 255, 0.2);
  border-top-color: var(--gold);
  border-radius: 50%;
  animation: spin-slow 1s linear infinite;
}

/* ================================================
   LOADING SCREEN - Pantalla de carga profesional
   ================================================ */
@keyframes loading-rotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes loading-pulse-ring {
  0%, 100% { 
    transform: scale(1); 
    opacity: 0.6; 
  }
  50% { 
    transform: scale(1.3); 
    opacity: 0.2; 
  }
}

@keyframes loading-bar {
  0% { 
    width: 0%; 
    background-position: 0% 50%;
  }
  50% { 
    width: 70%; 
    background-position: 100% 50%;
  }
  100% { 
    width: 100%; 
    background-position: 0% 50%;
  }
}

@keyframes loading-fade-in {
  0% { opacity: 0; transform: translateY(30px) scale(0.9); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes loading-shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.loading-shell {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 30% 20%, rgba(0, 212, 255, 0.12), transparent 50%),
    radial-gradient(circle at 70% 80%, rgba(96, 165, 250, 0.08), transparent 50%),
    linear-gradient(180deg, #07101c 0%, #0a1222 50%, #08101d 100%);
  padding: 1rem;
}

.loading-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
  padding: 3rem 2.5rem;
  background: 
    linear-gradient(145deg, rgba(15, 23, 42, 0.95), rgba(8, 16, 29, 0.98));
  border: 1px solid rgba(0, 212, 255, 0.15);
  border-radius: 32px;
  box-shadow: 
    0 40px 80px rgba(0, 0, 0, 0.5),
    0 0 60px rgba(0, 212, 255, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.05);
  text-align: center;
  animation: loading-fade-in 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  max-width: 380px;
  width: 100%;
}

.loading-logo {
  position: relative;
  width: 100px;
  height: 100px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-scissors {
  font-size: 2.8rem;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80px;
  height: 80px;
  background: linear-gradient(145deg, var(--gold), var(--gold-2));
  border-radius: 50%;
  color: #0a1a1f;
  font-weight: 800;
  animation: loading-rotate 3s linear infinite;
  box-shadow: 0 10px 30px rgba(0, 212, 255, 0.35);
  z-index: 2;
}

.loading-pulse {
  position: absolute;
  inset: -10px;
  border: 3px solid rgba(0, 212, 255, 0.4);
  border-radius: 50%;
  animation: loading-pulse-ring 1.5s ease-in-out infinite;
}

.loading-title {
  font-size: 1.8rem;
  font-weight: 800;
  margin: 0;
  letter-spacing: -0.03em;
  background: linear-gradient(135deg, #fff 0%, var(--gold) 50%, #fff 100%);
  background-size: 200% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: loading-shimmer 3s ease-in-out infinite;
}

.loading-subtitle {
  margin: 0;
  font-size: 1rem;
  color: var(--muted);
  font-weight: 500;
}

.loading-bar {
  width: 100%;
  height: 6px;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 3px;
  overflow: hidden;
  position: relative;
}

.loading-bar__fill {
  height: 100%;
  background: linear-gradient(90deg, var(--gold), var(--gold-2), var(--gold));
  background-size: 200% 100%;
  border-radius: 3px;
  animation: loading-bar 2s ease-in-out infinite;
}

.loading-hint {
  font-size: 0.85rem;
  color: rgba(159, 176, 208, 0.7);
  font-weight: 400;
}

@media (max-width: 480px) {
  .loading-card {
    padding: 2rem 1.5rem;
    border-radius: 24px;
    gap: 1.25rem;
  }
  
  .loading-logo {
    width: 80px;
    height: 80px;
  }
  
  .loading-scissors {
    width: 64px;
    height: 64px;
    font-size: 2.2rem;
  }
  
  .loading-title {
    font-size: 1.5rem;
  }
  
  .loading-subtitle {
    font-size: 0.9rem;
  }
}

/* ================================================
   BRAND TAGLINE
   ================================================ */
.brand-text {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.brand-tagline {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--gold);
  opacity: 0.85;
}

@media (max-width: 480px) {
  .brand-tagline {
    font-size: 0.65rem;
    display: none;
  }
}

/* ================================================
   HERO VIDEO BACKGROUND - Fondo de video
   ================================================ */
.hero-section--video {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 90vh;
  border-radius: 34px;
  overflow: hidden;
  padding: 2rem;
  box-shadow: 
    0 25px 80px rgba(0, 0, 0, 0.4),
    0 0 0 1px rgba(255, 255, 255, 0.05) inset;
}

.hero-video-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  background-color: #1a1a2e;
  background-image: url('https://images.pexels.com/photos/1805600/pexels-photo-1805600.jpeg?auto=compress&cs=tinysrgb&w=1920');
  background-size: cover;
  background-position: center;
}

.hero-video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(0.7) saturate(1.2) contrast(1.05);
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: 
    radial-gradient(ellipse at center, rgba(8, 16, 29, 0.3) 0%, rgba(8, 16, 29, 0.75) 100%),
    linear-gradient(180deg, rgba(8, 16, 29, 0.1) 0%, rgba(8, 16, 29, 0.6) 100%);
  z-index: 1;
}

.hero-copy--centered {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  max-width: 900px;
  animation: slide-in 0.8s ease-out;
}

.eyebrow--glow {
  color: var(--gold);
  text-shadow: 0 0 20px rgba(0, 212, 255, 0.5);
  animation: glow-pulse 3s ease-in-out infinite;
}

.hero-title--xl {
  font-size: clamp(3rem, 10vw, 8rem);
  font-weight: 900;
  letter-spacing: 0.15em;
  margin: 0.5rem 0 1rem;
  background: linear-gradient(135deg, #fff 0%, var(--gold) 50%, #fff 100%);
  background-size: 200% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: none;
  animation: loading-shimmer 3s ease-in-out infinite;
  text-transform: uppercase;
}

.hero-tagline {
  font-size: clamp(1.2rem, 2.5vw, 1.8rem);
  color: rgba(255, 255, 255, 0.95);
  max-width: 700px;
  line-height: 1.5;
  margin: 0 0 0.5rem;
  font-weight: 500;
  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
}

.hero-tagline--animated {
  animation: taglineReveal 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  animation-delay: 0.6s;
  opacity: 0;
}

.hero-actions--centered {
  justify-content: center;
}

.button--glow {
  animation: buttonPulse 2s ease-in-out infinite;
  box-shadow: 0 8px 30px rgba(0, 212, 255, 0.4);
  position: relative;
  overflow: hidden;
}

.button--glow::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(255, 255, 255, 0.3) 50%,
    transparent 70%
  );
  transform: rotate(45deg);
  animation: buttonShine 3s ease-in-out infinite;
}

@keyframes buttonPulse {
  0%, 100% {
    box-shadow: 0 8px 30px rgba(0, 212, 255, 0.4);
    transform: scale(1);
  }
  50% {
    box-shadow: 0 12px 40px rgba(0, 212, 255, 0.6);
    transform: scale(1.02);
  }
}

@keyframes buttonShine {
  0% {
    left: -100%;
  }
  50%, 100% {
    left: 100%;
  }
}

.button--glow:hover {
  box-shadow: 0 16px 50px rgba(0, 212, 255, 0.7);
  transform: scale(1.05);
}

/* Hero Features - Badges informativos */
.hero-features {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.75rem;
  margin: 1.5rem 0 2rem;
}

.hero-features--animated {
  animation: featuresReveal 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  animation-delay: 0.8s;
  opacity: 0;
}

@keyframes featuresReveal {
  0% {
    opacity: 0;
    transform: translateY(20px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero-feature {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.6rem 1rem;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(0, 212, 255, 0.3);
  border-radius: 50px;
  backdrop-filter: blur(10px);
  transition: all 0.3s ease;
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 500;
}

.hero-feature:hover {
  background: rgba(0, 212, 255, 0.15);
  border-color: rgba(0, 212, 255, 0.5);
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(0, 212, 255, 0.2);
}

.hero-feature__icon {
  font-size: 1.1rem;
}

/* Hero Buttons mejorados */
.button--hero {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 1rem 1.8rem;
  font-size: 1rem;
  font-weight: 700;
  border-radius: 50px;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.button--hero .button__icon {
  font-size: 1.2rem;
  transition: transform 0.3s ease;
}

.button--hero:hover .button__icon {
  transform: rotate(-20deg) scale(1.2);
}

.button--hero.button--ghost {
  border: 2px solid rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10px);
}

.button--hero.button--ghost:hover {
  background: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.5);
  transform: translateY(-3px);
}

@media (max-width: 768px) {
  .hero-features {
    gap: 0.5rem;
  }
  
  .hero-feature {
    padding: 0.5rem 0.8rem;
    font-size: 0.8rem;
  }
  
  .hero-feature__icon {
    font-size: 1rem;
  }
  
  .button--hero {
    padding: 0.9rem 1.4rem;
    font-size: 0.9rem;
  }
}

@media (max-width: 480px) {
  .hero-features {
    gap: 0.4rem;
  }
  
  .hero-feature {
    padding: 0.4rem 0.7rem;
    font-size: 0.75rem;
  }
  
  .button--hero {
    padding: 0.8rem 1.2rem;
    font-size: 0.85rem;
    width: 100%;
  }
  
  .hero-actions--centered {
    flex-direction: column;
    width: 100%;
    max-width: 280px;
  }
}

/* ================================================
   LETTER ANIMATION - AnimaciÃ³n de letras dinÃ¡mica
   Efecto estilo GSAP/Framer Motion con CSS puro
   ================================================ */
@keyframes letterReveal {
  0% {
    opacity: 0;
    transform: translateY(80px) rotateX(-90deg) scale(0.5);
    filter: blur(10px);
  }
  40% {
    opacity: 0.8;
    transform: translateY(-10px) rotateX(10deg) scale(1.1);
    filter: blur(2px);
  }
  60% {
    transform: translateY(5px) rotateX(-5deg) scale(0.98);
  }
  80% {
    transform: translateY(-2px) rotateX(2deg) scale(1.02);
  }
  100% {
    opacity: 1;
    transform: translateY(0) rotateX(0deg) scale(1);
    filter: blur(0);
  }
}

@keyframes letterGlow {
  0%, 100% {
    text-shadow: 
      0 0 10px rgba(0, 212, 255, 0.3),
      0 0 20px rgba(0, 212, 255, 0.2),
      0 0 30px rgba(0, 212, 255, 0.1);
  }
  50% {
    text-shadow: 
      0 0 20px rgba(0, 212, 255, 0.6),
      0 0 40px rgba(0, 212, 255, 0.4),
      0 0 60px rgba(0, 212, 255, 0.2),
      0 0 80px rgba(0, 212, 255, 0.1);
  }
}

@keyframes letterFloat {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8px);
  }
}

@keyframes taglineReveal {
  0% {
    opacity: 0;
    transform: translateY(30px);
    filter: blur(8px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }
}

@keyframes buttonsReveal {
  0% {
    opacity: 0;
    transform: translateY(40px) scale(0.9);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.hero-title--animated {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: nowrap;
  gap: 0;
  margin: 0.5rem 0 1rem;
  perspective: 1000px;
}

.title-word {
  display: inline-block;
  font-size: clamp(2.5rem, 8vw, 5rem);
  font-weight: 900;
  letter-spacing: 0.15em;
  color: transparent;
  background: linear-gradient(
    135deg, 
    #fff 0%, 
    var(--gold) 25%, 
    #fff 50%, 
    var(--gold) 75%, 
    #fff 100%
  );
  background-size: 400% 100%;
  -webkit-background-clip: text;
  background-clip: text;
  animation: 
    titleReveal 1.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards,
    letterGlow 3s ease-in-out infinite 1.2s,
    loading-shimmer 4s ease-in-out infinite 1.2s;
  opacity: 0;
  transform-style: preserve-3d;
  will-change: transform, opacity;
  white-space: nowrap;
  text-shadow: 0 4px 30px rgba(0, 212, 255, 0.3);
}

@keyframes titleReveal {
  0% {
    opacity: 0;
    transform: translateY(60px) scale(0.8);
    filter: blur(15px);
  }
  50% {
    opacity: 0.8;
    filter: blur(3px);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }
}

.hero-subtitle {
  font-size: clamp(0.85rem, 1.5vw, 1rem);
  color: rgba(255, 255, 255, 0.7);
  max-width: 600px;
  line-height: 1.6;
  margin: 0 0 1.5rem;
  text-align: center;
}

.hero-subtitle--animated {
  animation: subtitleReveal 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  animation-delay: 0.9s;
  opacity: 0;
}

@keyframes subtitleReveal {
  0% {
    opacity: 0;
    transform: translateY(20px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.letter-animate {
  display: inline-block;
  font-size: clamp(3rem, 12vw, 9rem);
  font-weight: 900;
  letter-spacing: 0.08em;
  color: transparent;
  background: linear-gradient(
    135deg, 
    #fff 0%, 
    var(--gold) 25%, 
    #fff 50%, 
    var(--gold) 75%, 
    #fff 100%
  );
  background-size: 400% 100%;
  -webkit-background-clip: text;
  background-clip: text;
  animation: 
    letterReveal 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards,
    letterGlow 3s ease-in-out infinite 1s,
    loading-shimmer 4s ease-in-out infinite 1s;
  opacity: 0;
  transform-style: preserve-3d;
  will-change: transform, opacity;
}

.letter-animate:hover {
  animation: 
    letterFloat 0.5s ease-in-out,
    letterGlow 1s ease-in-out infinite;
  cursor: default;
}

.hero-tagline--animated {
  animation: taglineReveal 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  animation-delay: 0.7s;
  opacity: 0;
}

.hero-actions--animated {
  animation: buttonsReveal 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  animation-delay: 1.2s;
  opacity: 0;
}

/* Efecto parallax sutil en las letras */
@media (hover: hover) {
  .hero-title--animated:hover .letter-animate {
    animation: letterGlow 1.5s ease-in-out infinite;
  }
  
  .hero-title--animated:hover .letter-animate:nth-child(odd) {
    animation: letterFloat 1.5s ease-in-out infinite;
  }
  
  .hero-title--animated:hover .letter-animate:nth-child(even) {
    animation: letterFloat 1.5s ease-in-out infinite 0.2s;
  }
}

/* Responsive para las letras */
@media (max-width: 768px) {
  .letter-animate {
    letter-spacing: 0.05em;
  }
  
  .hero-title--animated {
    gap: 0;
  }
}

@media (max-width: 480px) {
  .letter-animate {
    letter-spacing: 0.02em;
  }
}

@media (max-width: 768px) {
  .hero-section--video {
    min-height: 70vh;
    padding: 1.5rem;
    border-radius: 24px;
  }
  
  .hero-title--xl {
    letter-spacing: 0.08em;
  }
  
  .hero-tagline {
    font-size: 0.95rem;
  }
}

@media (max-width: 480px) {
  .hero-section--video {
    min-height: 60vh;
    border-radius: 20px;
  }
  
  .hero-title--xl {
    letter-spacing: 0.05em;
  }
}

/* ================================================
   TESTIMONIALS - SecciÃ³n de testimonios
   ================================================ */
.testimonials-section {
  padding: 3rem 0;
}

.testimonials-header {
  text-align: center;
  margin-bottom: 2.5rem;
}

.testimonials-title {
  font-size: clamp(1.5rem, 4vw, 2.2rem);
  font-weight: 800;
  margin: 0 0 0.5rem;
  color: var(--text);
  background: linear-gradient(135deg, #fff 0%, var(--gold) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.testimonials-subtitle {
  font-size: 1rem;
  color: var(--muted);
  margin: 0;
}

.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}

.testimonial-card {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding: 2rem;
  background: linear-gradient(145deg, rgba(15, 23, 42, 0.95), rgba(8, 16, 29, 0.98));
  border: 1px solid rgba(0, 212, 255, 0.12);
  border-radius: 24px;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  animation: testimonial-reveal 0.6s ease-out backwards;
  position: relative;
  overflow: hidden;
}

.testimonial-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.testimonial-card--featured {
  background: linear-gradient(145deg, rgba(0, 212, 255, 0.08), rgba(15, 23, 42, 0.95));
  border-color: rgba(0, 212, 255, 0.25);
}

.testimonial-card--featured::before {
  opacity: 1;
}

.testimonial-card:nth-child(1) { animation-delay: 0.1s; }
.testimonial-card:nth-child(2) { animation-delay: 0.2s; }
.testimonial-card:nth-child(3) { animation-delay: 0.3s; }
.testimonial-card:nth-child(4) { animation-delay: 0.4s; }
.testimonial-card:nth-child(5) { animation-delay: 0.5s; }
.testimonial-card:nth-child(6) { animation-delay: 0.6s; }

.testimonial-card:hover {
  transform: translateY(-10px) scale(1.02);
  border-color: rgba(0, 212, 255, 0.4);
  box-shadow: 
    0 25px 50px rgba(0, 212, 255, 0.15),
    0 0 0 1px rgba(0, 212, 255, 0.1) inset;
}

.testimonial-card:hover::before {
  opacity: 1;
}

.testimonial-quote {
  position: absolute;
  top: 1rem;
  right: 1.5rem;
  font-size: 4rem;
  font-family: serif;
  color: var(--gold);
  opacity: 0.15;
  line-height: 1;
  pointer-events: none;
}

.testimonial-stars {
  font-size: 1.1rem;
  letter-spacing: 0.15em;
  filter: drop-shadow(0 2px 4px rgba(0, 212, 255, 0.3));
}

.testimonial-text {
  font-size: 1.05rem;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.85);
  margin: 0;
  flex: 1;
  position: relative;
  z-index: 1;
}

.testimonial-footer {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-top: 0.5rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.testimonial-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--gold), var(--accent));
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 1rem;
  color: var(--background);
}

.testimonial-avatar--image {
  background: none;
  object-fit: cover;
  border: 2px solid var(--gold);
}

.testimonial-author {
  font-size: 0.95rem;
  color: var(--gold);
  font-weight: 600;
}

@keyframes testimonial-reveal {
  from {
    opacity: 0;
    transform: translateY(30px) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* Estado vacÃ­o de testimonios */
.testimonials-empty {
  grid-column: 1 / -1;
  text-align: center;
  padding: 3rem 2rem;
  background: rgba(255, 255, 255, 0.03);
  border: 1px dashed rgba(0, 212, 255, 0.3);
  border-radius: 16px;
}

.testimonials-empty p {
  color: var(--muted);
  font-size: 1.1rem;
  margin: 0;
}

/* Formulario de sugerencias */
.suggestion-section {
  display: flex;
  justify-content: center;
  margin-top: 1rem;
}

.suggestion-cta {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 1rem 2rem;
  font-size: 1.1rem;
  border-radius: 50px;
  animation: pulse-glow 2s ease-in-out infinite;
}

@keyframes pulse-glow {
  0%, 100% {
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.2);
  }
  50% {
    box-shadow: 0 0 30px rgba(0, 212, 255, 0.4);
  }
}

.suggestion-form {
  width: 100%;
  max-width: 500px;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding: 2rem;
  background: linear-gradient(145deg, rgba(15, 23, 42, 0.98), rgba(8, 16, 29, 0.95));
  border: 1px solid rgba(0, 212, 255, 0.2);
  border-radius: 24px;
  animation: scale-in 0.3s ease-out;
}

.suggestion-form__title {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--text);
  margin: 0 0 0.5rem;
  text-align: center;
}

.rating-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
}

.rating-picker__label {
  font-size: 0.9rem;
  color: var(--muted);
}

.rating-picker__stars {
  display: flex;
  gap: 0.25rem;
}

.rating-star {
  background: none;
  border: none;
  font-size: 1.8rem;
  cursor: pointer;
  transition: transform 0.2s ease;
  filter: grayscale(1) opacity(0.4);
}

.rating-star--active {
  filter: none;
  animation: star-pop 0.3s ease-out;
}

.rating-star:hover {
  transform: scale(1.2);
}

@keyframes star-pop {
  0% { transform: scale(1); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

.form-textarea {
  resize: vertical;
  min-height: 100px;
}

.suggestion-form__actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  margin-top: 0.5rem;
}

/* ================================================
   TESTIMONIALS ADMIN - Panel de administraciÃ³n
   ================================================ */
.testimonials-admin-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
  gap: 1.25rem;
}

.testimonial-admin-card {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  padding: 1.5rem;
  background: linear-gradient(145deg, rgba(15, 23, 42, 0.95), rgba(8, 16, 29, 0.98));
  border: 2px solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  transition: all 0.3s ease;
}

.testimonial-admin-card--pending {
  border-color: rgba(251, 191, 36, 0.3);
  background: linear-gradient(145deg, rgba(251, 191, 36, 0.05), rgba(8, 16, 29, 0.98));
}

.testimonial-admin-card--approved {
  border-color: rgba(34, 197, 94, 0.3);
}

.testimonial-admin-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.3);
}

.testimonial-admin-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
}

.testimonial-admin-info {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.testimonial-admin-info strong {
  color: var(--text);
  font-size: 1.1rem;
}

.testimonial-admin-info small {
  color: var(--muted);
  font-size: 0.8rem;
}

.testimonial-admin-date {
  color: var(--muted);
  opacity: 0.7;
}

.testimonial-admin-status {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.testimonial-admin-rating {
  font-size: 1.2rem;
  letter-spacing: 0.1em;
}

.testimonial-admin-message {
  font-size: 1rem;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.85);
  font-style: italic;
  margin: 0;
  flex: 1;
  padding: 0.75rem;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 8px;
  border-left: 3px solid var(--gold);
}

.testimonial-admin-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  padding-top: 0.75rem;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.testimonial-admin-actions .button {
  flex: 1;
  min-width: 100px;
}

@media (max-width: 768px) {
  .testimonials-admin-grid {
    grid-template-columns: 1fr;
  }
  
  .testimonial-admin-header {
    flex-direction: column;
  }
  
  .testimonial-admin-actions {
    flex-direction: column;
  }
  
  .testimonial-admin-actions .button {
    width: 100%;
  }
}

/* ================================================
   SHOWCASE SECTION - SecciÃ³n de galerÃ­a
   ================================================ */
.hero-showcase-section {
  padding: 1rem 0;
}

.showcase-section-title {
  text-align: center;
  font-size: clamp(1.3rem, 3vw, 1.8rem);
  font-weight: 800;
  margin: 0 0 1.25rem;
  color: var(--text);
}

/* ================================================
   INFO STRIP - Barra de informaciÃ³n de Barbados
   ================================================ */
.info-strip {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem;
  padding: 1.5rem;
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.08), rgba(96, 165, 250, 0.05));
  border: 1px solid rgba(0, 212, 255, 0.2);
  border-radius: 24px;
  animation: slide-in 0.6s ease-out;
}

.info-strip__item {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.75rem;
  border-radius: 16px;
  transition: all 0.3s ease;
}

.info-strip__item:hover {
  background: rgba(0, 212, 255, 0.1);
  transform: translateY(-2px);
}

.info-strip__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  background: linear-gradient(135deg, var(--gold), var(--gold-2));
  border-radius: 12px;
  font-size: 1.3rem;
  flex-shrink: 0;
}

.info-strip__item > div {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.info-strip__item strong {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--text);
}

.info-strip__item span {
  font-size: 0.8rem;
  color: var(--muted);
}

@media (max-width: 600px) {
  .info-strip {
    grid-template-columns: 1fr 1fr;
    padding: 1rem;
    gap: 0.75rem;
  }
  
  .info-strip__item {
    flex-direction: column;
    text-align: center;
    padding: 0.6rem;
  }
  
  .info-strip__icon {
    width: 40px;
    height: 40px;
    font-size: 1.1rem;
  }
  
  .info-strip__item strong {
    font-size: 0.8rem;
  }
  
  .info-strip__item span {
    font-size: 0.7rem;
  }
}

@media (max-width: 400px) {
  .info-strip {
    grid-template-columns: 1fr;
  }
  
  .info-strip__item {
    flex-direction: row;
    text-align: left;
  }
}

:root {
  color-scheme: dark;
  --bg: #08101d;
  --bg-2: #0f172a;
  --panel: rgba(15, 23, 42, 0.88);
  --panel-2: rgba(15, 23, 42, 0.95);
  --line: rgba(255, 255, 255, 0.08);
  --line-2: rgba(255, 255, 255, 0.14);
  --text: #eef2ff;
  --muted: #9fb0d0;
  --gold: #f4c76b;
  --gold-2: #b67f17;
  --green: #4ade80;
  --blue: #60a5fa;
  --red: #fb7185;
  --amber: #fbbf24;
  --shadow: 0 24px 60px rgba(2, 6, 23, 0.35);
}

* {
  box-sizing: border-box;
}

html,
body,
#root {
  min-height: 100%;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  background:
    radial-gradient(circle at top left, rgba(0, 212, 255, 0.18), transparent 24%),
    radial-gradient(circle at 80% 0%, rgba(96, 165, 250, 0.18), transparent 24%),
    radial-gradient(circle at 50% 100%, rgba(74, 222, 128, 0.08), transparent 26%),
    linear-gradient(180deg, #07101c 0%, #0a1222 45%, #08101d 100%);
  color: var(--text);
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

img {
  display: block;
  max-width: 100%;
}

button,
input,
select,
textarea {
  font: inherit;
}

button {
  cursor: pointer;
}

.site-shell {
  min-height: 100vh;
  padding: 1.25rem;
}

.site-header,
.panel,
.auth-card,
.auth-side-card,
.hero-section,
.hero-panel,
.hero-stat,
.landing-card,
.kpi-card,
.entity-card,
.shop-card,
.profile-card,
.conversation-item,
.message-bubble,
.composer-card,
.attachment-chip,
.list-row,
.cart-row,
.mini-stat,
.alert,
.nav-button,
.status-chip,
.empty-state,
.checkout-card,
.coverage-item,
.auth-card--center {
  border: 1px solid var(--line);
  background: var(--panel);
  box-shadow: var(--shadow);
}

.site-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.25rem;
  border-radius: 28px;
  padding: 1rem 1.5rem;
  backdrop-filter: blur(20px) saturate(180%);
  background: linear-gradient(135deg, rgba(18, 18, 35, 0.85), rgba(26, 26, 50, 0.9)) !important;
  border: 1px solid rgba(0, 212, 255, 0.2) !important;
  box-shadow: 
    0 8px 32px rgba(0, 0, 0, 0.3),
    0 0 60px rgba(0, 212, 255, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.05) !important;
  position: relative;
  overflow: hidden;
  transition: all 0.4s var(--ease-smooth);
}

.site-header::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 200%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(0, 212, 255, 0.1),
    rgba(131, 56, 236, 0.05),
    transparent
  );
  animation: header-shimmer 8s linear infinite;
}

@keyframes header-shimmer {
  0% { transform: translateX(-50%); }
  100% { transform: translateX(50%); }
}

.site-header:hover {
  border-color: rgba(0, 212, 255, 0.4) !important;
  box-shadow: 
    0 12px 40px rgba(0, 0, 0, 0.4),
    0 0 80px rgba(0, 212, 255, 0.15),
    inset 0 1px 0 rgba(255, 255, 255, 0.08) !important;
}

.site-brand {
  display: flex;
  align-items: center;
  gap: 1rem;
  position: relative;
  z-index: 2;
}

.brand-mark {
  display: grid;
  height: 60px;
  width: 60px;
  place-items: center;
  border-radius: 18px;
  background: var(--gradient-main);
  background-size: 200% 200%;
  color: #ffffff;
  font-size: 1.7rem;
  font-weight: 800;
  animation: brand-glow 3s ease-in-out infinite;
  transition: all 0.4s var(--ease-spring);
  box-shadow: 0 8px 30px rgba(0, 212, 255, 0.4);
  position: relative;
  overflow: hidden;
}

.brand-mark::before {
  content: '';
  position: absolute;
  inset: -2px;
  background: var(--gradient-main);
  background-size: 300% 300%;
  border-radius: 20px;
  z-index: -1;
  animation: border-rotate 4s linear infinite;
  opacity: 0.7;
}

@keyframes brand-glow {
  0%, 100% { 
    background-position: 0% 50%;
    box-shadow: 0 8px 30px rgba(0, 212, 255, 0.4);
  }
  50% { 
    background-position: 100% 50%;
    box-shadow: 0 8px 40px rgba(131, 56, 236, 0.5);
  }
}

@keyframes border-rotate {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.brand-mark:hover {
  transform: scale(1.1) rotate(-5deg);
  box-shadow: 0 15px 50px rgba(0, 212, 255, 0.6);
}

.site-brand h1,
.hero-copy h2,
.auth-card h1,
.auth-card h2,
.auth-side-card h2 {
  margin: 0.18rem 0 0;
  letter-spacing: -0.04em;
}

.site-brand h1 {
  font-size: 1.35rem;
}

.eyebrow,
.kpi-title,
.metric-label {
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #b0f4ff;
}

.site-nav {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: flex-end;
  gap: 0.55rem;
}

.nav-link,
.button,
.input,
.select,
.textarea,
.badge,
.nav-button {
  border-radius: 16px;
}

.nav-link {
  border: 1px solid transparent;
  background: rgba(255, 255, 255, 0.03);
  padding: 0.72rem 1.1rem;
  color: var(--muted);
  transition: all 0.4s var(--ease-spring);
  position: relative;
  overflow: hidden;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.nav-link::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 0;
  height: 2px;
  background: var(--gradient-main);
  transition: all 0.4s var(--ease-spring);
  transform: translateX(-50%);
}

.nav-link::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at center, rgba(0, 212, 255, 0.2), transparent 70%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.nav-link:hover {
  border-color: rgba(0, 212, 255, 0.4);
  background: rgba(0, 212, 255, 0.1);
  color: var(--text-primary);
  transform: translateY(-3px);
  box-shadow: 0 8px 25px rgba(0, 212, 255, 0.2);
}

.nav-link:hover::before {
  width: 80%;
}

.nav-link:hover::after {
  opacity: 1;
}

.nav-link--active {
  border-color: rgba(0, 212, 255, 0.5);
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.15), rgba(131, 56, 236, 0.1));
  color: var(--text-primary);
  box-shadow: 
    0 4px 20px rgba(0, 212, 255, 0.25),
    inset 0 1px 0 rgba(255, 255, 255, 0.1);
}

.nav-link--active::before {
  width: 80%;
}

.alert {
  margin-bottom: 1rem;
  border-radius: 20px;
  padding: 0.9rem 1rem;
}

.alert--danger {
  background: rgba(251, 113, 133, 0.12);
  color: #ffd6de;
}

.alert--success {
  background: rgba(74, 222, 128, 0.12);
  color: #d0fade;
}

/* Notification Toast */
@keyframes toast-slide-in {
  from {
    opacity: 0;
    transform: translateX(100%) scale(0.9);
  }
  to {
    opacity: 1;
    transform: translateX(0) scale(1);
  }
}

@keyframes toast-pulse {
  0%, 100% {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 0 0 0 rgba(0, 212, 255, 0);
  }
  50% {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 0 0 8px rgba(0, 212, 255, 0.15);
  }
}

.notification-toast {
  position: fixed;
  top: 1.5rem;
  right: 1.5rem;
  z-index: 9999;
  display: flex;
  align-items: flex-start;
  gap: 0.85rem;
  max-width: 420px;
  min-width: 300px;
  padding: 1rem 1.25rem;
  border-radius: 20px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(8, 16, 29, 0.98));
  backdrop-filter: blur(20px);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), 0 0 60px rgba(0, 212, 255, 0.1);
  animation: toast-slide-in 0.4s cubic-bezier(0.16, 1, 0.3, 1), toast-pulse 2s ease-in-out infinite;
}

.notification-toast--notification {
  border-color: rgba(96, 165, 250, 0.3);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), 0 0 40px rgba(96, 165, 250, 0.15);
}

.notification-toast--message {
  border-color: rgba(74, 222, 128, 0.3);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), 0 0 40px rgba(74, 222, 128, 0.15);
}

.notification-toast__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: 14px;
  font-size: 1.4rem;
  flex-shrink: 0;
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.2), rgba(182, 127, 23, 0.1));
}

.notification-toast--notification .notification-toast__icon {
  background: linear-gradient(135deg, rgba(96, 165, 250, 0.2), rgba(59, 130, 246, 0.1));
}

.notification-toast--message .notification-toast__icon {
  background: linear-gradient(135deg, rgba(74, 222, 128, 0.2), rgba(34, 197, 94, 0.1));
}

.notification-toast__content {
  flex: 1;
  min-width: 0;
}

.notification-toast__title {
  display: block;
  margin-bottom: 0.25rem;
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--text);
}

.notification-toast__text {
  margin: 0;
  font-size: 0.88rem;
  color: var(--muted);
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.notification-toast__close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border: none;
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.08);
  color: var(--muted);
  font-size: 1.2rem;
  cursor: pointer;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.notification-toast__close:hover {
  background: rgba(251, 113, 133, 0.2);
  color: #fb7185;
}

/* ========================================
   BANNER DE MENSAJES NO LEÃDOS
======================================== */
@keyframes bannerSlideIn {
  0% {
    transform: translateX(100%);
    opacity: 0;
  }
  60% {
    transform: translateX(-5%);
  }
  100% {
    transform: translateX(0);
    opacity: 1;
  }
}

@keyframes bannerPulse {
  0%, 100% {
    box-shadow: 0 8px 32px rgba(139, 92, 246, 0.3);
  }
  50% {
    box-shadow: 0 8px 40px rgba(139, 92, 246, 0.5), 0 0 20px rgba(139, 92, 246, 0.3);
  }
}

.unread-banner {
  position: fixed;
  bottom: 1.5rem;
  right: 1.5rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.25rem;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.95), rgba(109, 40, 217, 0.95));
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 16px;
  box-shadow: 0 8px 32px rgba(139, 92, 246, 0.3);
  backdrop-filter: blur(12px);
  z-index: 9999;
  max-width: 420px;
  animation: bannerSlideIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), bannerPulse 3s ease-in-out infinite;
  animation-delay: 0s, 0.5s;
}

.unread-banner__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  font-size: 1.5rem;
  flex-shrink: 0;
  animation: iconPulse 2s ease-in-out infinite;
}

.unread-banner__content {
  flex: 1;
  min-width: 0;
}

.unread-banner__content strong {
  display: block;
  font-size: 0.95rem;
  font-weight: 700;
  color: #fff;
  margin-bottom: 0.25rem;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
}

.unread-banner__content p {
  margin: 0;
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.unread-banner__action {
  padding: 0.6rem 1rem;
  background: rgba(255, 255, 255, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 10px;
  color: #fff;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
  white-space: nowrap;
}

.unread-banner__action:hover {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(1.02);
}

.unread-banner__action--secondary {
  background: rgba(0, 0, 0, 0.2);
  border-color: rgba(255, 255, 255, 0.2);
  font-size: 0.8rem;
}

.unread-banner__action--secondary:hover {
  background: rgba(0, 0, 0, 0.3);
}

.unread-banner__close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  background: rgba(255, 255, 255, 0.1);
  border: none;
  border-radius: 50%;
  color: rgba(255, 255, 255, 0.8);
  font-size: 1.1rem;
  cursor: pointer;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.unread-banner__close:hover {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
}

@media (max-width: 500px) {
  .unread-banner {
    bottom: 0.75rem;
    right: 0.75rem;
    left: 0.75rem;
    max-width: none;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
  }
  
  .unread-banner__icon {
    width: 40px;
    height: 40px;
    font-size: 1.2rem;
  }
  
  .unread-banner__content strong {
    font-size: 0.9rem;
  }
  
  .unread-banner__content p {
    font-size: 0.8rem;
  }
  
  .unread-banner__action {
    padding: 0.5rem 0.85rem;
    font-size: 0.8rem;
  }
}

@media (max-width: 600px) {
  .notification-toast {
    top: 0.75rem;
    right: 0.75rem;
    left: 0.75rem;
    max-width: none;
    min-width: 0;
    padding: 0.85rem 1rem;
  }
  
  .notification-toast__icon {
    width: 38px;
    height: 38px;
    font-size: 1.2rem;
  }
  
  .notification-toast__title {
    font-size: 0.88rem;
  }
  
  .notification-toast__text {
    font-size: 0.82rem;
  }

  .barbers-grid {
    grid-template-columns: 1fr;
  }

  .barber-card {
    padding: 1.25rem;
  }

  .barber-card__avatar {
    width: 70px;
    height: 70px;
  }

  .barber-card__name {
    font-size: 1rem;
  }
}

.landing-shell,
.content-shell {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.hero-section {
  display: grid;
  gap: 1.2rem;
  grid-template-columns: 1.5fr 0.9fr;
  border-radius: 34px;
  padding: 1.5rem;
  background:
    radial-gradient(circle at top right, rgba(96, 165, 250, 0.16), transparent 32%),
    radial-gradient(circle at bottom left, rgba(0, 212, 255, 0.14), transparent 28%),
    linear-gradient(180deg, rgba(15, 23, 42, 0.97), rgba(8, 16, 29, 0.97));
}

.hero-section--dynamic {
  position: relative;
  overflow: hidden;
}

.hero-section--dynamic::before,
.hero-section--dynamic::after {
  content: "";
  position: absolute;
  border-radius: 999px;
  filter: blur(40px);
  opacity: 0.34;
  pointer-events: none;
}

.hero-section--dynamic::before {
  top: -70px;
  right: -40px;
  height: 220px;
  width: 220px;
  background: rgba(96, 165, 250, 0.28);
}

.hero-section--dynamic::after {
  bottom: -70px;
  left: -40px;
  height: 220px;
  width: 220px;
  background: rgba(0, 212, 255, 0.22);
}

.hero-copy p,
.auth-card p,
.auth-side-card p,
.panel-subtitle,
.entity-card p,
.shop-body p,
.coverage-item p,
.list-row-main span,
.list-row-main small,
.profile-card span,
.profile-card small,
.mini-stat span,
.empty-state span,
.hero-stat span {
  color: var(--muted);
}

.hero-copy h2 {
  font-size: clamp(2rem, 4vw, 3.6rem);
  max-width: 720px;
  animation: slide-in 0.8s ease-out 0.1s backwards;
}

.hero-copy p {
  max-width: 760px;
  font-size: 1.05rem;
  line-height: 1.7;
  animation: slide-in 0.8s ease-out 0.2s backwards;
}

.hero-actions,
.actions-inline,
.site-nav,
.field-actions,
.top-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.7rem;
}

.hero-panel {
  display: grid;
  gap: 1rem;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  border-radius: 30px;
  padding: 1rem;
}

.hero-showcase {
  display: grid;
  gap: 1rem;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.showcase-card,
.hero-pill,
.premium-strip__item,
.entity-chip {
  border: 1px solid var(--line);
  background: rgba(255, 255, 255, 0.04);
  box-shadow: var(--shadow);
}

.showcase-card {
  position: relative;
  overflow: hidden;
  display: flex;
  min-height: 200px;
  flex-direction: column;
  justify-content: space-between;
  gap: 0.5rem;
  border-radius: 26px;
  padding: 1rem;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  animation: slide-in 0.6s ease forwards;
}

.showcase-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(15, 23, 42, 0.05), rgba(15, 23, 42, 0.02));
  backdrop-filter: blur(1px);
  z-index: 1;
  pointer-events: none;
}

.showcase-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  filter: brightness(1) saturate(1.2) contrast(1.1);
  z-index: 0;
}

.showcase-card > span,
.showcase-card > strong,
.showcase-card > small {
  position: relative;
  z-index: 2;
}

.showcase-card:hover {
  transform: translateY(-8px) scale(1.02);
  border-color: rgba(0, 212, 255, 0.4);
  box-shadow: 0 20px 50px rgba(0, 212, 255, 0.15), var(--shadow);
}

.showcase-card:hover .showcase-image {
  filter: brightness(0.9) saturate(1.2) contrast(1.15);
  transform: scale(1.05);
}

.showcase-card strong {
  font-size: 1.8rem;
  font-weight: 800;
}

.showcase-card small {
  color: var(--muted);
}

.showcase-card--primary {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.22), rgba(182, 127, 23, 0.14));
}

.showcase-card--accent {
  background: linear-gradient(135deg, rgba(96, 165, 250, 0.2), rgba(59, 130, 246, 0.12));
}

.hero-inline-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-top: 1rem;
  animation: slide-in 0.8s ease-out 0.3s backwards;
}

.hero-pill {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  border-radius: 18px;
  padding: 0.8rem 0.95rem;
  transition: all 0.3s ease;
  animation: scale-in 0.5s ease-out;
}

.hero-pill:hover {
  transform: translateY(-4px);
  border-color: rgba(0, 212, 255, 0.3);
  background: rgba(0, 212, 255, 0.08);
}

.hero-pill span,
.showcase-card span {
  color: var(--muted);
}

.hero-pill strong {
  font-size: 1rem;
}

.premium-strip {
  display: grid;
  gap: 1rem;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  animation: slide-in 0.8s ease-out;
}

.premium-strip__item {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  border-radius: 22px;
  padding: 1rem;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.premium-strip__item:hover {
  transform: translateY(-6px);
  border-color: rgba(0, 212, 255, 0.3);
  background: rgba(0, 212, 255, 0.08);
}

.premium-strip__item span {
  color: var(--muted);
}

.landing-grid--featured {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.cards-grid--showcase {
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
}

.entity-card--interactive {
  position: relative;
  overflow: visible;
  transition: all 0.5s var(--ease-spring);
  animation: card-enter 0.6s var(--ease-out-expo);
  transform-style: preserve-3d;
  perspective: 1000px;
}

@keyframes card-enter {
  0% {
    opacity: 0;
    transform: translateY(40px) rotateX(10deg) scale(0.9);
    filter: blur(10px);
  }
  100% {
    opacity: 1;
    transform: translateY(0) rotateX(0) scale(1);
    filter: blur(0);
  }
}

.entity-card--interactive::before {
  content: "";
  position: absolute;
  inset: -2px;
  background: var(--gradient-main);
  background-size: 300% 300%;
  border-radius: inherit;
  z-index: -1;
  opacity: 0;
  transition: opacity 0.4s ease;
  animation: border-rotate 4s linear infinite paused;
}

.entity-card--interactive::after {
  content: "";
  position: absolute;
  inset: auto -40% -60% auto;
  height: 180px;
  width: 180px;
  border-radius: 999px;
  background: radial-gradient(circle, rgba(0, 212, 255, 0.2), rgba(131, 56, 236, 0.1), transparent);
  filter: blur(40px);
  transition: all 0.5s ease;
  opacity: 0;
  pointer-events: none;
}

.entity-card--interactive:hover {
  transform: translateY(-12px) scale(1.04) rotateX(2deg);
  border-color: rgba(0, 212, 255, 0.5) !important;
  box-shadow: 
    0 30px 60px rgba(0, 212, 255, 0.15),
    0 0 60px rgba(131, 56, 236, 0.1),
    var(--shadow);
}

.entity-card--interactive:hover::before {
  opacity: 0.6;
  animation-play-state: running;
}

.entity-card--interactive:hover::after {
  opacity: 1;
  inset: auto -10% -10% auto;
  transform: scale(1.2);
}

.entity-card--glow {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.12), rgba(131, 56, 236, 0.08));
  border: 1px solid rgba(0, 212, 255, 0.25);
  animation: card-glow 3s ease-in-out infinite;
}

@keyframes card-glow {
  0%, 100% { 
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.2), 0 8px 30px rgba(0, 0, 0, 0.3);
  }
  50% { 
    box-shadow: 0 0 40px rgba(0, 212, 255, 0.4), 0 0 60px rgba(131, 56, 236, 0.2), 0 12px 40px rgba(0, 0, 0, 0.3);
  }
}

.entity-chip {
  display: inline-flex;
  width: fit-content;
  border-radius: 999px;
  padding: 0.38rem 0.75rem;
  font-size: 0.72rem;
  font-weight: 800;
  color: #b0f4ff;
}

.entity-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
}

/* ========================================
   BARBER CARDS - Tarjetas de barberos
   Animaciones dinÃ¡micas
======================================== */
@keyframes avatarGlow {
  0%, 100% { box-shadow: 0 4px 16px rgba(201, 169, 106, 0.3); }
  50% { box-shadow: 0 8px 30px rgba(201, 169, 106, 0.5), 0 0 20px rgba(201, 169, 106, 0.3); }
}

@keyframes barberCardEnter {
  0% {
    opacity: 0;
    transform: translateY(30px) scale(0.95);
  }
  70% {
    transform: translateY(-3px) scale(1.01);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.barbers-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 1.5rem;
  perspective: 1000px;
}

.barber-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  padding: 2rem 1.5rem;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02));
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 20px;
  text-align: center;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  animation: barberCardEnter 0.5s ease-out backwards;
  position: relative;
  overflow: hidden;
}

.barber-card:nth-child(1) { animation-delay: 0.05s; }
.barber-card:nth-child(2) { animation-delay: 0.15s; }
.barber-card:nth-child(3) { animation-delay: 0.25s; }
.barber-card:nth-child(4) { animation-delay: 0.35s; }

/* Efecto de brillo al hover */
.barber-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.04),
    rgba(255, 255, 255, 0.08),
    rgba(255, 255, 255, 0.04),
    transparent
  );
  transform: skewX(-15deg);
  transition: left 0.6s ease;
}

.barber-card:hover::before {
  left: 150%;
}

.barber-card:hover {
  transform: translateY(-8px) rotateX(2deg);
  box-shadow: 
    0 20px 40px rgba(0, 0, 0, 0.35),
    0 0 30px rgba(201, 169, 106, 0.1);
  border-color: rgba(201, 169, 106, 0.25);
}

.barber-card__avatar {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  object-fit: cover;
  border: 3px solid var(--color-gold);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  animation: avatarGlow 3s ease-in-out infinite;
  position: relative;
}

.barber-card:hover .barber-card__avatar {
  transform: scale(1.1) rotate(5deg);
  border-width: 4px;
  animation: avatarGlow 1.5s ease-in-out infinite;
}

.barber-card__info {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  transition: transform 0.3s ease;
}

.barber-card:hover .barber-card__info {
  transform: translateY(-2px);
}

.barber-card__name {
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--color-text-primary);
  transition: all 0.3s ease;
}

.barber-card:hover .barber-card__name {
  text-shadow: 0 0 15px rgba(255, 255, 255, 0.2);
}

.barber-card__role {
  font-size: 0.9rem;
  color: var(--color-gold);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  opacity: 0.85;
  transition: all 0.3s ease;
}

.barber-card:hover .barber-card__role {
  opacity: 1;
  letter-spacing: 0.08em;
}

.barber-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  width: 100%;
  margin-top: 0.5rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
  transition: border-color 0.3s ease;
}

.barber-card:hover .barber-card__footer {
  border-color: rgba(201, 169, 106, 0.2);
}

/* ========================================
   TARJETAS DE SERVICIO - Service Cards
   Animaciones dinÃ¡micas y efectos visuales
======================================== */

/* Animaciones keyframe */
@keyframes cardFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

@keyframes iconPulse {
  0%, 100% { transform: scale(1); box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2); }
  50% { transform: scale(1.05); box-shadow: 0 12px 30px rgba(var(--accent-rgb), 0.25); }
}

@keyframes shimmer {
  0% { left: -100%; }
  100% { left: 200%; }
}

@keyframes gradientShift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

@keyframes borderGlow {
  0%, 100% { border-color: rgba(var(--accent-rgb), 0.2); }
  50% { border-color: rgba(var(--accent-rgb), 0.5); }
}

@keyframes priceGlow {
  0%, 100% { filter: brightness(1) drop-shadow(0 0 0 transparent); }
  50% { filter: brightness(1.2) drop-shadow(0 0 10px rgba(var(--accent-rgb), 0.4)); }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes cardEnter {
  0% {
    opacity: 0;
    transform: translateY(40px) scale(0.9);
  }
  60% {
    transform: translateY(-5px) scale(1.02);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1rem;
  perspective: 1000px;
}

.service-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: linear-gradient(145deg, rgba(30, 30, 35, 0.9), rgba(20, 20, 25, 0.95));
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 24px;
  padding: 2rem 1.5rem;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  overflow: hidden;
  animation: cardEnter 0.6s ease-out backwards;
  transform-style: preserve-3d;
}

.service-card:nth-child(1) { animation-delay: 0.1s; }
.service-card:nth-child(2) { animation-delay: 0.2s; }
.service-card:nth-child(3) { animation-delay: 0.3s; }
.service-card:nth-child(4) { animation-delay: 0.4s; }
.service-card:nth-child(5) { animation-delay: 0.5s; }
.service-card:nth-child(6) { animation-delay: 0.6s; }

/* Efecto de brillo que recorre la tarjeta */
.service-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.05),
    rgba(255, 255, 255, 0.1),
    rgba(255, 255, 255, 0.05),
    transparent
  );
  transform: skewX(-20deg);
  transition: left 0.7s ease;
  pointer-events: none;
}

/* LÃ­nea de acento superior animada */
.service-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  width: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--accent), var(--secondary), var(--accent));
  background-size: 200% 100%;
  animation: gradientShift 3s ease infinite;
  transition: width 0.4s ease, left 0.4s ease;
  border-radius: 0 0 3px 3px;
}

.service-card:hover {
  transform: translateY(-12px) rotateX(2deg);
  border-color: rgba(var(--accent-rgb), 0.3);
  box-shadow: 
    0 25px 50px rgba(0, 0, 0, 0.5),
    0 0 40px rgba(var(--accent-rgb), 0.15),
    inset 0 1px 0 rgba(255, 255, 255, 0.1);
  animation: borderGlow 2s ease infinite;
}

.service-card:hover::before {
  left: 200%;
}

.service-card:hover::after {
  width: 100%;
  left: 0;
}

/* Icono con animaciones */
.service-card__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80px;
  height: 80px;
  background: linear-gradient(
    135deg,
    rgba(var(--accent-rgb), 0.25),
    rgba(var(--secondary-rgb), 0.2)
  );
  background-size: 200% 200%;
  border-radius: 50%;
  margin-bottom: 1.5rem;
  font-size: 2.2rem;
  box-shadow: 
    0 10px 30px rgba(0, 0, 0, 0.25),
    inset 0 2px 10px rgba(255, 255, 255, 0.1);
  transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  position: relative;
  animation: iconPulse 3s ease-in-out infinite;
}

/* Anillo exterior del icono */
.service-card__icon::before {
  content: '';
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  border: 2px dashed rgba(var(--accent-rgb), 0.3);
  opacity: 0;
  transition: all 0.4s ease;
  animation: none;
}

.service-card:hover .service-card__icon {
  transform: scale(1.15) rotate(10deg);
  box-shadow: 
    0 15px 40px rgba(var(--accent-rgb), 0.35),
    inset 0 2px 15px rgba(255, 255, 255, 0.15);
  animation: gradientShift 2s ease infinite;
}

.service-card:hover .service-card__icon::before {
  opacity: 1;
  animation: spin 8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.service-card__title {
  font-size: 1.3rem;
  font-weight: 700;
  color: #fff;
  margin-bottom: 0.75rem;
  letter-spacing: -0.02em;
  transition: all 0.3s ease;
  position: relative;
}

.service-card:hover .service-card__title {
  transform: scale(1.05);
  text-shadow: 0 0 20px rgba(255, 255, 255, 0.3);
}

.service-card__description {
  font-size: 0.9rem;
  color: var(--muted);
  line-height: 1.6;
  margin-bottom: 1.25rem;
  flex-grow: 1;
  transition: color 0.3s ease;
}

.service-card:hover .service-card__description {
  color: rgba(255, 255, 255, 0.7);
}

.service-card__meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.5rem;
  padding: 1rem 0;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
  width: 100%;
  margin-bottom: 1rem;
  transition: all 0.3s ease;
}

.service-card:hover .service-card__meta {
  border-color: rgba(var(--accent-rgb), 0.2);
}

.service-card__price {
  font-size: 1.6rem;
  font-weight: 800;
  background: linear-gradient(135deg, var(--accent), var(--secondary), var(--accent));
  background-size: 200% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  transition: all 0.3s ease;
}

.service-card:hover .service-card__price {
  animation: gradientShift 2s ease infinite, priceGlow 1.5s ease infinite;
  transform: scale(1.1);
}

.service-card__duration {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.85rem;
  color: var(--muted);
  padding: 0.4rem 0.8rem;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20px;
  transition: all 0.3s ease;
}

.service-card:hover .service-card__duration {
  background: rgba(var(--accent-rgb), 0.15);
  color: rgba(255, 255, 255, 0.9);
  transform: scale(1.05);
}

.service-card__book-btn {
  width: 100%;
  padding: 1rem 1.5rem;
  background: linear-gradient(135deg, var(--accent), var(--secondary));
  background-size: 200% 100%;
  border: none;
  border-radius: 14px;
  color: #fff;
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4px 15px rgba(var(--accent-rgb), 0.2);
}

.service-card__book-btn::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: width 0.6s ease, height 0.6s ease;
}

.service-card__book-btn:hover {
  transform: translateY(-3px) scale(1.02);
  box-shadow: 
    0 10px 30px rgba(var(--accent-rgb), 0.4),
    0 0 20px rgba(var(--accent-rgb), 0.2);
  animation: gradientShift 1.5s ease infinite;
}

.service-card__book-btn:hover::before {
  width: 300px;
  height: 300px;
}

.service-card__book-btn:active {
  transform: translateY(-1px) scale(0.98);
  box-shadow: 0 5px 15px rgba(var(--accent-rgb), 0.3);
}

/* Variante destacada - mÃ¡s llamativa */
.service-card--featured {
  border-color: rgba(var(--accent-rgb), 0.4);
  background: linear-gradient(
    145deg,
    rgba(45, 35, 55, 0.95),
    rgba(25, 20, 35, 0.98)
  );
  animation: cardEnter 0.6s ease-out backwards, cardFloat 4s ease-in-out infinite;
  animation-delay: 0.1s, 0.7s;
}

.service-card--featured::after {
  content: 'â­ Popular';
  position: absolute;
  top: 1rem;
  right: 1rem;
  padding: 0.4rem 0.85rem;
  background: linear-gradient(135deg, var(--accent), var(--secondary), var(--accent));
  background-size: 200% 100%;
  border-radius: 25px;
  font-size: 0.7rem;
  font-weight: 700;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  animation: gradientShift 3s ease infinite;
  box-shadow: 0 4px 15px rgba(var(--accent-rgb), 0.4);
  width: auto;
  height: auto;
  left: auto;
}

.service-card--featured .service-card__icon {
  animation: iconPulse 2s ease-in-out infinite;
}

/* Ocultar badge HTML redundante (se usa ::after para featured) */
.service-card__badge {
  display: none;
}

/* Responsive */
@media (max-width: 640px) {
  .services-grid {
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 0 0.75rem;
  }
  
  .service-card {
    padding: 1.5rem 1.25rem;
  }
  
  .service-card__icon {
    width: 70px;
    height: 70px;
    font-size: 1.75rem;
  }
  
  .service-card__title {
    font-size: 1.1rem;
  }
  
  .service-card__price {
    font-size: 1.3rem;
  }
}

.coverage-grid--premium {
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
}

.coverage-item--premium {
  min-height: 110px;
  border-radius: 24px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.03));
}

.hero-stat,
.kpi-card,
.mini-stat {
  border-radius: 24px;
  padding: 1rem;
}

.mini-stat {
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.mini-stat:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.2);
}

.mini-stat small {
  color: var(--muted);
  font-size: 0.75rem;
  display: block;
  margin-top: 0.25rem;
}

.mini-stat--success {
  background: linear-gradient(135deg, rgba(74, 222, 128, 0.16), rgba(255, 255, 255, 0.03));
  border: 1px solid rgba(74, 222, 128, 0.15);
}

.mini-stat--info {
  background: linear-gradient(135deg, rgba(96, 165, 250, 0.16), rgba(255, 255, 255, 0.03));
  border: 1px solid rgba(96, 165, 250, 0.15);
}

.mini-stat--warning {
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.16), rgba(255, 255, 255, 0.03));
  border: 1px solid rgba(251, 191, 36, 0.15);
}

.mini-stat--accent {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.16), rgba(255, 255, 255, 0.03));
  border: 1px solid rgba(0, 212, 255, 0.15);
}

.kpi-card {
  position: relative;
  overflow: hidden;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  animation: kpi-appear 0.6s ease forwards;
  animation-delay: calc(var(--kpi-index, 0) * 0.1s);
  opacity: 0;
}

@keyframes kpi-appear {
  0% {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.kpi-card::before {
  content: "";
  position: absolute;
  top: -100%;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), transparent);
  transition: top 0.6s ease;
}

.kpi-card::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 3px;
  background: linear-gradient(90deg, var(--gold), var(--accent));
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.4s ease;
}

.kpi-card:hover {
  transform: translateY(-8px) scale(1.02);
  border-color: rgba(0, 212, 255, 0.35);
  box-shadow: 0 16px 40px rgba(0, 212, 255, 0.12), var(--shadow);
}

.kpi-card:hover::before {
  top: 0;
}

.kpi-card:hover::after {
  transform: scaleX(1);
}

/* KPI card icons */
.kpi-icon {
  font-size: 2rem;
  margin-bottom: 0.5rem;
  display: block;
  animation: kpi-icon-bounce 2s ease infinite;
}

@keyframes kpi-icon-bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

/* KPI enhanced value display */
.kpi-value {
  font-size: 2rem;
  font-weight: 800;
  background: linear-gradient(135deg, var(--text), var(--gold));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.kpi-title {
  font-size: 0.85rem;
  color: var(--text-2);
  letter-spacing: 0.5px;
  text-transform: uppercase;
  font-weight: 600;
}

/* KPI card color variants */
.kpi-card--success .kpi-value {
  background: linear-gradient(135deg, #4ade80, #22c55e);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.kpi-card--info .kpi-value {
  background: linear-gradient(135deg, #60a5fa, #3b82f6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.kpi-card--warning .kpi-value {
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.kpi-card--danger .kpi-value {
  background: linear-gradient(135deg, #fb7185, #ef4444);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-stat strong,
.kpi-value,
.mini-stat strong {
  display: block;
  margin-top: 0.35rem;
  font-size: 1.55rem;
  font-weight: 800;
}

.landing-grid,
.dashboard-grid,
.kpi-grid,
.cards-grid,
.coverage-grid,
.auth-layout-grid,
.dashboard-shell,
.chat-layout,
.form-grid,
.mini-stats {
  display: grid;
  gap: 1rem;
}

.landing-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.dashboard-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.dashboard-grid--full,
.panel--full {
  grid-column: 1 / -1;
}

/* Panel span utilities for grid layouts */
.panel--span-2 {
  grid-column: span 2;
}

.panel--span-3 {
  grid-column: span 3;
}

.kpi-grid,
.mini-stats {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.cards-grid,
.coverage-grid {
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.auth-layout-grid {
  grid-template-columns: 1.1fr 0.9fr;
}

.panel,
.auth-card,
.auth-side-card,
.landing-card {
  border-radius: 28px;
  padding: 1.2rem;
  animation: slide-in 0.6s ease-out;
}

.landing-card {
  transition: all 0.3s ease;
}

.landing-card:hover {
  border-color: rgba(0, 212, 255, 0.15);
  box-shadow: 0 12px 40px rgba(0, 212, 255, 0.08), var(--shadow);
}

.auth-card,
.auth-side-card {
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
  min-width: min(100%, 560px);
}

.auth-card--center {
  text-align: center;
  border-radius: 28px;
  padding: 2rem;
}

.page-shell-auth {
  display: flex;
  min-height: calc(100vh - 140px);
  align-items: center;
  justify-content: center;
  padding: 1rem 0;
}

.input,
.select,
.textarea {
  width: 100%;
  border: 1px solid var(--line-2);
  background: rgba(255, 255, 255, 0.04);
  padding: 0.9rem 1rem;
  color: var(--text);
  outline: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border-radius: 14px;
}

.input::placeholder,
.textarea::placeholder {
  color: rgba(159, 176, 208, 0.5);
}

.input:hover,
.select:hover,
.textarea:hover {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(0, 212, 255, 0.2);
}

.input:focus,
.select:focus,
.textarea:focus {
  border-color: rgba(0, 212, 255, 0.6);
  background: rgba(255, 255, 255, 0.08);
  box-shadow: 0 0 0 4px rgba(0, 212, 255, 0.12), inset 0 0 0 1px rgba(0, 212, 255, 0.1);
}

.textarea {
  min-height: 120px;
  resize: vertical;
}

.button {
  border: 1px solid transparent;
  padding: 0.8rem 1rem;
  color: var(--text);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  font-weight: 600;
  letter-spacing: 0.5px;
}

.button::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.1);
  transition: left 0.3s ease;
  z-index: -1;
}

.button:hover {
  transform: translateY(-4px) scale(1.02);
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4), 0 0 20px rgba(0, 212, 255, 0.2);
}

.button:hover::before {
  left: 100%;
}

.button:active {
  transform: translateY(-1px) scale(0.98);
}

.button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

.button--primary {
  background: var(--gradient-main);
  background-size: 200% 200%;
  color: #ffffff;
  font-weight: 800;
  box-shadow: 0 8px 30px rgba(0, 212, 255, 0.3);
  animation: btn-gradient 4s ease infinite;
  position: relative;
  overflow: hidden;
}

@keyframes btn-gradient {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

.button--primary::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(255, 255, 255, 0.3) 50%,
    transparent 70%
  );
  transform: rotate(45deg);
  animation: btn-shine 3s ease-in-out infinite;
}

@keyframes btn-shine {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

.button--primary:hover {
  box-shadow: 
    0 15px 40px rgba(0, 212, 255, 0.4),
    0 0 40px rgba(131, 56, 236, 0.3);
  filter: brightness(1.15);
  animation-play-state: paused;
}

.button--ghost {
  border-color: rgba(0, 212, 255, 0.3);
  background: rgba(0, 212, 255, 0.05);
}

.button--ghost:hover {
  border-color: rgba(0, 212, 255, 0.6);
  background: rgba(0, 212, 255, 0.15);
  box-shadow: 0 0 30px rgba(0, 212, 255, 0.2);
}

.button--small {
  padding: 0.58rem 0.72rem;
  font-size: 0.88rem;
}

.button--danger {
  background: rgba(255, 0, 110, 0.15);
  color: #ffd5dd;
  border-color: rgba(255, 0, 110, 0.3);
}

.button--danger:hover {
  background: rgba(255, 0, 110, 0.25);
  border-color: rgba(255, 0, 110, 0.5);
  box-shadow: 0 0 25px rgba(255, 0, 110, 0.3);
}

.button--success {
  background: rgba(0, 245, 212, 0.15);
  color: #d0fade;
  border-color: rgba(0, 245, 212, 0.3);
}

.button--success:hover {
  background: rgba(0, 245, 212, 0.25);
  border-color: rgba(74, 222, 128, 0.4);
}

.button--warning {
  background: rgba(251, 191, 36, 0.16);
  color: #ffefc2;
  border-color: rgba(251, 191, 36, 0.2);
}

.button--warning:hover {
  background: rgba(251, 191, 36, 0.24);
  border-color: rgba(251, 191, 36, 0.4);
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.35rem 0.7rem;
  font-size: 0.75rem;
  font-weight: 700;
}

.badge--info {
  background: rgba(96, 165, 250, 0.14);
  color: #d7eaff;
}

.badge--success {
  background: rgba(74, 222, 128, 0.14);
  color: #d0fade;
}

.badge--warning {
  background: rgba(251, 191, 36, 0.14);
  color: #b0f4ff;
}

.badge--danger {
  background: rgba(251, 113, 133, 0.14);
  color: #ffd5dd;
}

.panel-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1rem;
}

.panel-title {
  margin: 0;
  font-size: 1.1rem;
  font-weight: 800;
  letter-spacing: -0.03em;
}

.panel-subtitle {
  margin: 0.3rem 0 0;
  max-width: 720px;
}

.entity-card,
.shop-card,
.coverage-item,
.empty-state,
.checkout-card {
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
  border-radius: 24px;
  padding: 1rem;
}

.entity-card__header,
.shop-meta,
.checkout-line,
.cart-row,
.list-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
}

.shop-card {
  overflow: hidden;
  padding: 0;
  display: flex;
  flex-direction: column;
  transition: all 0.5s var(--ease-spring);
  animation: card-enter 0.6s var(--ease-out-expo);
  position: relative;
  transform-style: preserve-3d;
}

.shop-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--gradient-glow);
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
  z-index: 1;
}

.shop-card--interactive {
  cursor: pointer;
}

.shop-card--interactive:hover {
  transform: translateY(-15px) scale(1.03) rotateY(3deg);
  border-color: rgba(0, 212, 255, 0.5) !important;
  box-shadow: 
    0 30px 60px rgba(0, 212, 255, 0.2),
    0 0 80px rgba(131, 56, 236, 0.1),
    var(--shadow);
}

.shop-card--interactive:hover::before {
  opacity: 1;
}

.shop-image-wrapper {
  position: relative;
  overflow: hidden;
  aspect-ratio: 1 / 1;
  width: 100%;
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.1), rgba(131, 56, 236, 0.1));
}

.shop-thumb {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: all 0.6s var(--ease-smooth);
  filter: saturate(0.9);
}

.shop-card--interactive:hover .shop-thumb {
  transform: scale(1.15) rotate(2deg);
  filter: saturate(1.2) brightness(1.1);
}

.shop-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(10, 10, 18, 0.9), rgba(18, 18, 35, 0.7));
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  opacity: 0;
  transition: opacity 0.3s ease;
  backdrop-filter: blur(4px);
  padding: 1rem;
}

.shop-card--interactive:hover .shop-overlay {
  opacity: 1;
}

.shop-body {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 0.85rem;
  padding: 1.2rem;
  background: var(--panel);
}

.shop-category {
  font-size: 0.85rem;
  color: var(--muted);
  margin: 0.2rem 0 0 0;
}

.shop-description {
  font-size: 0.95rem;
  line-height: 1.5;
  color: var(--muted);
  flex-grow: 1;
}

.shop-price {
  font-size: 1.6rem;
  color: var(--gold);
  font-weight: 800;
}

.button--large {
  padding: 1rem 1.5rem;
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: 0.5px;
}

.dashboard-shell {
  grid-template-columns: 280px 1fr;
}

.dashboard-sidebar {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
  border-radius: 28px;
  padding: 1.2rem;
  text-align: center;
}

.avatar {
  height: 48px;
  width: 48px;
  border-radius: 16px;
  object-fit: cover;
}

.avatar--large {
  height: 88px;
  width: 88px;
  border-radius: 24px;
}

.nav-list {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}

.nav-button {
  padding: 0.9rem 1rem;
  color: var(--text);
  text-align: left;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border-radius: 14px;
  position: relative;
  overflow: hidden;
}

.nav-button::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: 0;
  background: rgba(0, 212, 255, 0.1);
  transition: width 0.3s ease;
  border-radius: 14px;
  z-index: -1;
}

.nav-button:hover,
.nav-button--active {
  color: var(--gold);
  border-color: rgba(0, 212, 255, 0.28);
  background: rgba(0, 212, 255, 0.12);
}

.nav-button:hover::before,
.nav-button--active::before {
  width: 100%;
}

/* Badge para indicar mensajes/notificaciones no leÃ­dos */
.nav-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 20px;
  height: 20px;
  padding: 0 6px;
  margin-left: 0.5rem;
  background: linear-gradient(135deg, #ef4444, #dc2626);
  border-radius: 10px;
  font-size: 0.7rem;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  animation: badgePulse 2s ease-in-out infinite;
  box-shadow: 0 2px 8px rgba(239, 68, 68, 0.4);
}

@keyframes badgePulse {
  0%, 100% { 
    transform: scale(1);
    box-shadow: 0 2px 8px rgba(239, 68, 68, 0.4);
  }
  50% { 
    transform: scale(1.1);
    box-shadow: 0 3px 12px rgba(239, 68, 68, 0.6);
  }
}

.dashboard-content {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.metric-bars {
  display: grid;
  align-items: end;
  gap: 0.8rem;
  grid-template-columns: repeat(12, minmax(0, 1fr));
  min-height: 220px;
}

.metric-bars--condensed {
  min-height: 210px;
}

.metric-column {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
  transition: transform 0.3s ease;
}

.metric-column:hover {
  transform: translateY(-5px);
}

.metric-track {
  display: flex;
  height: 150px;
  width: 100%;
  align-items: end;
  overflow: hidden;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.05);
}

.metric-fill {
  width: 100%;
  height: var(--size);
  border-radius: 999px;
  background: linear-gradient(180deg, var(--gold), var(--gold-2));
  animation: metric-grow 1s ease-out forwards;
  transform-origin: bottom;
  transition: all 0.3s ease;
}

@keyframes metric-grow {
  from {
    transform: scaleY(0);
  }
  to {
    transform: scaleY(1);
  }
}

.metric-column:hover .metric-fill {
  background: linear-gradient(180deg, var(--accent), var(--gold));
  box-shadow: 0 4px 20px rgba(0, 212, 255, 0.3);
}

.metric-amount {
  font-size: 0.72rem;
  color: var(--muted);
  writing-mode: vertical-rl;
  text-orientation: mixed;
}

.table-wrap {
  overflow-x: auto;
}

.table {
  width: 100%;
  border-collapse: collapse;
}

.table th,
.table td {
  border-bottom: 1px solid var(--line);
  padding: 0.9rem 0.75rem;
  text-align: left;
  vertical-align: top;
}

.table th {
  color: #b0f4ff;
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.data-list {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}

.list-row,
.cart-row,
.conversation-item,
.composer-card,
.attachment-chip,
.empty-state,
.checkout-card,
.message-bubble {
  border-radius: 22px;
  padding: 0.95rem 1rem;
}

.attachment-chip {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.attachment-chip img {
  border: 1px solid var(--line);
}

.chat-layout {
  grid-template-columns: 290px 1fr;
}

.chat-sidebar,
.chat-main {
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
}

.chat-sidebar {
  min-height: 620px;
}

.chat-main {
  min-height: 620px;
}

.admin-chat-starter {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding: 0.8rem;
  background: rgba(99, 102, 241, 0.1);
  border: 1px solid rgba(99, 102, 241, 0.3);
  border-radius: 12px;
  margin-bottom: 0.5rem;
}

.admin-chat-starter .label {
  font-size: 0.85rem;
  color: var(--primary);
  font-weight: 500;
}

.admin-chat-starter .input {
  font-size: 0.9rem;
}

.conversation-item {
  width: 100%;
  text-align: left;
  color: var(--text);
  background: rgba(255, 255, 255, 0.04);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
  border-radius: 14px;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem;
}

.conversation-item::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: 0;
  background: rgba(0, 212, 255, 0.08);
  transition: width 0.3s ease;
  z-index: -1;
}

.conversation-item:hover {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(0, 212, 255, 0.2);
}

.conversation-item:hover::before {
  width: 100%;
}

.conversation-item--active {
  border-color: rgba(0, 212, 255, 0.36);
  background: linear-gradient(90deg, rgba(0, 212, 255, 0.12), rgba(0, 212, 255, 0.05));
  box-shadow: inset -3px 0 0 rgba(0, 212, 255, 0.5);
}

.conversation-item__avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
  border: 2px solid rgba(0, 212, 255, 0.3);
}

.conversation-item__info {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
  min-width: 0;
  flex: 1;
}

.conversation-item__info strong {
  font-size: 0.95rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.conversation-item__info span {
  font-size: 0.8rem;
  opacity: 0.7;
}

.conversation-item__info small {
  font-size: 0.75rem;
  opacity: 0.6;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.chat-toolbar__users {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.chat-toolbar__avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid rgba(0, 212, 255, 0.4);
  margin-left: -12px;
}

.chat-toolbar__avatar:first-child {
  margin-left: 0;
}

.message-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
  align-self: flex-end;
  border: 2px solid rgba(255, 255, 255, 0.1);
}

.messages-area {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 0.8rem;
  overflow: auto;
  border: 1px solid var(--line);
  border-radius: 28px;
  background: rgba(255, 255, 255, 0.03);
  padding: 1rem;
}

.message-row {
  display: flex;
  justify-content: flex-start;
  align-items: flex-end;
  gap: 0.5rem;
}

.message-row--own {
  justify-content: flex-end;
}

.message-bubble {
  max-width: min(70%, 550px);
}

.message-bubble--own {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.16), rgba(0, 212, 255, 0.08));
}

.message-bubble strong {
  display: block;
  margin-bottom: 0.35rem;
}

.message-bubble p {
  margin: 0;
  line-height: 1.55;
}

.message-image {
  margin-top: 0.8rem;
  max-height: 240px;
  width: 100%;
  border-radius: 18px;
  object-fit: cover;
}

.voice-card {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin-top: 0.6rem;
  padding: 0.6rem;
  background: rgba(99, 102, 241, 0.15);
  border-radius: 12px;
  border: 1px solid rgba(99, 102, 241, 0.3);
}

.voice-card audio {
  width: 100%;
  border-radius: 8px;
  background: rgba(0, 0, 0, 0.2);
}

.voice-card audio::-webkit-media-controls-panel {
  background: linear-gradient(135deg, #1e1e2e 0%, #2d2d44 100%);
}

.voice-duration {
  font-size: 0.8rem;
  color: var(--muted);
  text-align: center;
}

.composer-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 0.7rem;
}

.mic-icon {
  font-size: 1.1rem;
  display: inline-block;
}

.mic-icon--recording {
  animation: mic-pulse 0.8s ease-in-out infinite;
  color: #fb7185;
}

.recording-btn {
  animation: recording-glow 1s ease-in-out infinite;
  background: linear-gradient(135deg, #fb7185 0%, #ef4444 100%) !important;
  border-color: #fb7185 !important;
}

.file-button {
  position: relative;
  overflow: hidden;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
  min-height: 44px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.file-button input[type="file"] {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  cursor: pointer;
  font-size: 100px;
  -webkit-tap-highlight-color: transparent;
}

.empty-state {
  align-items: center;
  justify-content: center;
  min-height: 180px;
  text-align: center;
}

.coverage-item {
  display: flex;
  gap: 0.7rem;
  animation: slide-in 0.6s ease-out;
  transition: all 0.3s ease;
}

.coverage-item:hover {
  transform: translateX(8px);
}

.user-cell {
  display: flex;
  align-items: center;
  gap: 0.8rem;
}

.actions-inline--center {
  justify-content: center;
}

.actions-inline--wrap {
  flex-wrap: wrap;
}

.coverage-item span {
  color: var(--green);
  font-weight: 800;
}

.danger-zone {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  border: 1px dashed rgba(251, 113, 133, 0.38);
  border-radius: 24px;
  padding: 1rem;
  background: rgba(251, 113, 133, 0.08);
}

.form-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.field--full {
  grid-column: 1 / -1;
}

@media (max-width: 1180px) {
  .hero-section,
  .dashboard-shell,
  .auth-layout-grid,
  .chat-layout,
  .landing-grid,
  .kpi-grid,
  .mini-stats,
  .form-grid,
  .dashboard-grid,
  .metric-bars,
  .hero-showcase,
  .premium-strip,
  .landing-grid--featured {
    grid-template-columns: 1fr;
  }

  /* Panel spans collapse to full width on tablets */
  .panel--span-2,
  .panel--span-3 {
    grid-column: 1 / -1;
  }

  .chat-sidebar,
  .chat-main {
    min-height: auto;
  }
  
  .metric-bars {
    grid-template-columns: repeat(6, minmax(0, 1fr));
    min-height: 180px;
  }
  
  .dashboard-shell {
    grid-template-columns: 1fr;
  }
  
  .dashboard-sidebar {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  
  .profile-card {
    flex-direction: row;
    justify-content: flex-start;
    text-align: left;
    gap: 1rem;
    flex: 1;
    min-width: 280px;
  }
  
  .nav-list {
    flex-direction: row;
    flex-wrap: wrap;
    flex: 1;
  }
}

@media (max-width: 960px) {
  .kpi-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .cards-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .hero-showcase {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .premium-strip {
    grid-template-columns: repeat(2, 1fr);
  }
  
  /* Mini stats 2 columns on medium screens */
  .mini-stats {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 780px) {
  .site-shell {
    padding: 0.85rem;
  }

  .site-header,
  .hero-section,
  .panel,
  .auth-card,
  .auth-side-card,
  .profile-card {
    border-radius: 24px;
  }

  .site-header,
  .panel-header,
  .entity-card__header,
  .shop-meta,
  .checkout-line,
  .list-row,
  .cart-row {
    flex-direction: column;
  }

  .site-nav {
    justify-content: flex-start;
  }

  .message-bubble {
    max-width: 100%;
  }
  
  .brand-mark {
    width: 48px;
    height: 48px;
    font-size: 1.3rem;
  }
  
  .site-brand h1 {
    font-size: 1.1rem;
  }
  
  .hero-copy h2 {
    font-size: 1.8rem;
  }
  
  .metric-bars {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    min-height: 150px;
  }
  
  .metric-track {
    height: 100px;
  }
  
  .metric-amount {
    font-size: 0.6rem;
  }
  
  .kpi-grid {
    grid-template-columns: 1fr;
  }
  
  .avatar--large {
    width: 64px;
    height: 64px;
  }
  
  .dashboard-sidebar {
    flex-direction: column;
  }
  
  .profile-card {
    flex-direction: column;
    text-align: center;
  }
  
  .nav-list {
    flex-direction: row;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    -webkit-overflow-scrolling: touch;
  }
  
  .nav-button {
    white-space: nowrap;
    flex-shrink: 0;
    padding: 0.7rem 0.9rem;
    font-size: 0.9rem;
  }
  
  .mini-stats {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 600px) {
  .site-shell {
    padding: 0.6rem;
  }
  
  .site-header {
    padding: 0.75rem;
    border-radius: 20px;
    flex-wrap: wrap;
  }
  
  .site-brand {
    gap: 0.6rem;
  }
  
  .brand-mark {
    width: 40px;
    height: 40px;
    font-size: 1.1rem;
    border-radius: 12px;
  }
  
  .site-brand h1 {
    font-size: 1rem;
  }
  
  .site-nav {
    width: 100%;
    justify-content: center;
    gap: 0.4rem;
  }
  
  .nav-link {
    padding: 0.55rem 0.7rem;
    font-size: 0.8rem;
    border-radius: 12px;
  }
  
  .hero-section {
    padding: 1rem;
    border-radius: 20px;
  }
  
  .hero-copy h2 {
    font-size: 1.5rem;
  }
  
  .hero-copy p {
    font-size: 0.9rem;
  }
  
  .hero-actions {
    flex-direction: column;
  }
  
  .hero-actions .button {
    width: 100%;
  }
  
  .hero-inline-metrics {
    flex-direction: column;
  }
  
  .hero-showcase {
    grid-template-columns: 1fr;
  }
  
  .showcase-card {
    min-height: 150px;
  }
  
  .premium-strip {
    grid-template-columns: 1fr;
  }
  
  .cards-grid {
    grid-template-columns: 1fr;
  }
  
  .panel {
    padding: 1rem;
    border-radius: 18px;
  }
  
  .panel-title {
    font-size: 1rem;
  }
  
  .entity-card,
  .shop-card,
  .checkout-card {
    border-radius: 18px;
  }
  
  .button {
    padding: 0.7rem 0.9rem;
    font-size: 0.9rem;
    border-radius: 12px;
  }
  
  .button--small {
    padding: 0.5rem 0.6rem;
    font-size: 0.8rem;
  }
  
  .input,
  .select,
  .textarea {
    padding: 0.75rem 0.85rem;
    font-size: 0.9rem;
    border-radius: 12px;
  }
  
  .metric-bars {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    min-height: 120px;
  }
  
  .metric-track {
    height: 80px;
  }
  
  .mini-stats {
    grid-template-columns: 1fr;
  }
  
  .mini-stat {
    padding: 0.9rem;
  }
  
  .list-row,
  .cart-row {
    padding: 0.75rem;
    border-radius: 16px;
  }
  
  .messages-area {
    padding: 0.75rem;
    border-radius: 18px;
  }
  
  .conversation-item {
    padding: 0.7rem;
  }
  
  .chat-layout {
    gap: 0.75rem;
  }
  
  .auth-card,
  .auth-side-card {
    padding: 1.25rem;
    border-radius: 20px;
  }
  
  .auth-card h2 {
    font-size: 1.3rem;
  }
  
  .table th,
  .table td {
    padding: 0.6rem 0.5rem;
    font-size: 0.85rem;
  }
}

@media (max-width: 400px) {
  .site-shell {
    padding: 0.4rem;
  }
  
  .site-header {
    padding: 0.6rem;
    margin-bottom: 0.75rem;
  }
  
  .brand-mark {
    width: 36px;
    height: 36px;
    font-size: 1rem;
  }
  
  .site-brand h1 {
    font-size: 0.9rem;
  }
  
  .nav-link {
    padding: 0.45rem 0.55rem;
    font-size: 0.75rem;
  }
  
  .hero-copy h2 {
    font-size: 1.3rem;
  }
  
  .hero-copy p {
    font-size: 0.85rem;
    line-height: 1.5;
  }
  
  .button {
    padding: 0.6rem 0.75rem;
    font-size: 0.85rem;
  }
  
  .panel {
    padding: 0.8rem;
    border-radius: 16px;
  }
  
  .avatar--large {
    width: 56px;
    height: 56px;
    border-radius: 16px;
  }
  
  .profile-card {
    padding: 1rem;
  }
  
  .nav-button {
    padding: 0.55rem 0.7rem;
    font-size: 0.8rem;
  }
  
  .metric-bars {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  
  .kpi-value {
    font-size: 1.4rem;
  }
}

/* Large screens - TV & 4K monitors */
@media (min-width: 1600px) {
  .site-shell {
    padding: 2rem;
    max-width: 1800px;
    margin: 0 auto;
  }
  
  .hero-section {
    padding: 2.5rem;
    grid-template-columns: 1.4fr 1fr;
  }
  
  .hero-copy h2 {
    font-size: 3.2rem;
  }
  
  .hero-copy p {
    font-size: 1.15rem;
  }
  
  .dashboard-shell {
    grid-template-columns: 320px 1fr;
  }
  
  .kpi-grid {
    grid-template-columns: repeat(4, 1fr);
  }
  
  .cards-grid {
    grid-template-columns: repeat(4, 1fr);
  }
  
  .avatar--large {
    width: 100px;
    height: 100px;
    border-radius: 28px;
  }
}

@media (min-width: 2000px) {
  .site-shell {
    padding: 2.5rem;
    max-width: 2200px;
  }
  
  .hero-copy h2 {
    font-size: 3.8rem;
  }
  
  .button {
    padding: 1rem 1.3rem;
    font-size: 1.05rem;
  }
  
  .panel {
    padding: 1.8rem;
  }
  
  .cards-grid {
    grid-template-columns: repeat(5, 1fr);
  }
}

/* ===========================================
   RESPONSIVE TEXT UTILITIES
   =========================================== */

/* Fluid typography base */
html {
  font-size: clamp(14px, 1.2vw + 10px, 18px);
}

/* Text scaling classes */
.text-fluid-xs {
  font-size: clamp(0.65rem, 0.6rem + 0.25vw, 0.8rem);
}

.text-fluid-sm {
  font-size: clamp(0.75rem, 0.7rem + 0.3vw, 0.95rem);
}

.text-fluid-base {
  font-size: clamp(0.85rem, 0.8rem + 0.35vw, 1.05rem);
}

.text-fluid-lg {
  font-size: clamp(1rem, 0.9rem + 0.5vw, 1.3rem);
}

.text-fluid-xl {
  font-size: clamp(1.2rem, 1rem + 0.8vw, 1.8rem);
}

.text-fluid-2xl {
  font-size: clamp(1.5rem, 1.2rem + 1.2vw, 2.5rem);
}

.text-fluid-3xl {
  font-size: clamp(1.8rem, 1.4rem + 1.8vw, 3.5rem);
}

/* Responsive text adjustments for all elements */
body {
  font-size: clamp(0.875rem, 0.8rem + 0.3vw, 1rem);
  line-height: 1.6;
}

h1, .text-h1 {
  font-size: clamp(1.5rem, 1.2rem + 1.5vw, 2.8rem);
  line-height: 1.2;
}

h2, .text-h2 {
  font-size: clamp(1.3rem, 1rem + 1.2vw, 2.2rem);
  line-height: 1.25;
}

h3, .text-h3 {
  font-size: clamp(1.1rem, 0.9rem + 0.8vw, 1.6rem);
  line-height: 1.3;
}

p, span, small, label {
  font-size: clamp(0.8rem, 0.75rem + 0.25vw, 1rem);
}

small {
  font-size: clamp(0.7rem, 0.65rem + 0.2vw, 0.85rem);
}

/* Responsive panel titles */
.panel-title {
  font-size: clamp(0.95rem, 0.85rem + 0.4vw, 1.25rem);
}

.panel-subtitle {
  font-size: clamp(0.8rem, 0.75rem + 0.2vw, 0.95rem);
}

/* Responsive KPIs */
.kpi-value {
  font-size: clamp(1.4rem, 1.1rem + 1vw, 2.2rem);
}

.kpi-title {
  font-size: clamp(0.65rem, 0.6rem + 0.2vw, 0.8rem);
}

/* Responsive nav items */
.nav-link,
.nav-button {
  font-size: clamp(0.8rem, 0.75rem + 0.2vw, 0.95rem);
}

/* Responsive buttons */
.button {
  font-size: clamp(0.8rem, 0.75rem + 0.2vw, 0.95rem);
}

.button--small {
  font-size: clamp(0.7rem, 0.65rem + 0.15vw, 0.85rem);
}

/* Responsive cards */
.entity-card strong,
.shop-card strong {
  font-size: clamp(0.9rem, 0.85rem + 0.25vw, 1.1rem);
}

/* Responsive stats */
.mini-stat strong {
  font-size: clamp(1.1rem, 0.95rem + 0.5vw, 1.5rem);
}

.mini-stat span,
.mini-stat small {
  font-size: clamp(0.7rem, 0.65rem + 0.15vw, 0.85rem);
}

/* Responsive hero */
.hero-copy h2 {
  font-size: clamp(1.5rem, 1rem + 2.5vw, 3.6rem);
}

.hero-copy p {
  font-size: clamp(0.9rem, 0.85rem + 0.3vw, 1.1rem);
}

/* Responsive forms */
.input,
.select,
.textarea {
  font-size: clamp(0.85rem, 0.8rem + 0.2vw, 1rem);
}

/* Responsive badges */
.badge {
  font-size: clamp(0.65rem, 0.6rem + 0.15vw, 0.8rem);
}

/* Responsive eyebrow */
.eyebrow {
  font-size: clamp(0.65rem, 0.6rem + 0.15vw, 0.78rem);
}

/* Text truncation utilities */
.text-truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-wrap {
  word-wrap: break-word;
  overflow-wrap: break-word;
}

/* Line clamping */
.line-clamp-1 {
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.line-clamp-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ================================================
   ENHANCED UX - Interacciones y Feedback Visual
   ================================================ */

/* Focus visible para accesibilidad */
:focus-visible {
  outline: 2px solid var(--gold);
  outline-offset: 2px;
}

/* Scroll suave global */
* {
  scroll-behavior: smooth;
}

/* Touch targets mÃ­nimos para mÃ³vil - 44px */
button,
.nav-link,
.nav-button,
.button,
.file-button,
input[type="file"],
select {
  min-height: 44px;
}

/* Mejora de rendimiento para animaciones */
.site-header,
.panel,
.entity-card,
.shop-card,
.kpi-card,
.landing-card,
.message-bubble,
.conversation-item,
.button {
  will-change: transform;
  backface-visibility: hidden;
}

/* TransiciÃ³n global suave */
* {
  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
}

/* Estado de hover mejorado para todos los interactivos */
button:not(:disabled):active,
.button:not(:disabled):active {
  transform: scale(0.97);
}

/* Indicador de carga para botones */
.button--loading {
  position: relative;
  color: transparent !important;
  pointer-events: none;
}

.button--loading::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 18px;
  height: 18px;
  margin: -9px 0 0 -9px;
  border: 2px solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: loading-rotate 0.8s linear infinite;
}

/* Skeleton loading para contenido */
.skeleton {
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0.04) 0%,
    rgba(255, 255, 255, 0.08) 50%,
    rgba(255, 255, 255, 0.04) 100%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: 8px;
}

/* ================================================
   MEJORAS RESPONSIVE AVANZADAS
   ================================================ */

/* Container queries support */
@supports (container-type: inline-size) {
  .dashboard-content,
  .chat-main,
  .panel--full {
    container-type: inline-size;
  }
}

/* Mejor espaciado en tablets */
@media (min-width: 768px) and (max-width: 1024px) {
  .dashboard-shell {
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  
  .dashboard-sidebar {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: start;
  }
  
  .profile-card {
    flex-direction: row;
    justify-content: flex-start;
    gap: 1rem;
  }
  
  .nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .chat-layout {
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  
  .chat-sidebar {
    max-height: 300px;
    overflow-y: auto;
  }
}

/* Landscape phone optimization */
@media (max-width: 812px) and (orientation: landscape) {
  .hero-section {
    padding: 1rem;
    min-height: auto;
  }
  
  .hero-copy h2 {
    font-size: 1.4rem;
  }
  
  .loading-shell {
    padding: 0.5rem;
  }
  
  .loading-card {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    padding: 1.5rem;
    max-width: 100%;
  }
  
  .loading-logo {
    width: 60px;
    height: 60px;
  }
  
  .loading-scissors {
    width: 48px;
    height: 48px;
    font-size: 1.5rem;
  }
  
  .loading-title {
    font-size: 1.3rem;
  }
  
  .loading-bar {
    max-width: 200px;
  }
}

/* Mejoras de accesibilidad para dark mode */
@media (prefers-contrast: high) {
  :root {
    --line: rgba(255, 255, 255, 0.2);
    --line-2: rgba(255, 255, 255, 0.3);
    --muted: #c8d4e8;
  }
  
  .button {
    border-width: 2px;
  }
}

/* Reduce motion para usuarios sensibles */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
  
  .loading-scissors {
    animation: none;
  }
  
  .loading-pulse {
    animation: none;
    opacity: 0.4;
  }
  
  .loading-bar__fill {
    animation: none;
    width: 50%;
  }
}

/* ================================================
   OPTIMIZACIONES PARA PANTALLAS TÃCTILES
   ================================================ */
@media (hover: none) and (pointer: coarse) {
  /* Quitar efectos hover que no funcionan en tÃ¡ctil */
  .entity-card--interactive:hover,
  .shop-card--interactive:hover,
  .kpi-card:hover,
  .showcase-card:hover {
    transform: none;
  }
  
  /* Efecto de tap feedback mejorado */
  .button:active,
  .nav-link:active,
  .nav-button:active {
    background: rgba(0, 212, 255, 0.25);
    transform: scale(0.98);
  }
  
  /* TamaÃ±os de touch comfortables */
  .nav-link,
  .nav-button {
    min-height: 48px;
    padding: 0.8rem 1rem;
  }
  
  /* Scroll momentum para iOS */
  .messages-area,
  .data-list,
  .table-wrap,
  .nav-list {
    -webkit-overflow-scrolling: touch;
  }
}

/* ================================================
   SOPORTE PARA MODO OSCURO DEL SISTEMA
   ================================================ */
@media (prefers-color-scheme: light) {
  /* Forzar tema oscuro siempre para mantener consistencia de marca */
  :root {
    color-scheme: dark;
  }
}

/* ================================================
   PRINT STYLES - Para impresiÃ³n
   ================================================ */
@media print {
  .site-header,
  .site-nav,
  .dashboard-sidebar,
  .nav-list,
  .button,
  .loading-shell {
    display: none !important;
  }
  
  .site-shell {
    padding: 0;
    background: white;
    color: black;
  }
  
  .panel,
  .entity-card,
  .kpi-card {
    page-break-inside: avoid;
    border: 1px solid #ccc;
    box-shadow: none;
    background: white;
  }
}

/* ================================================
   UTILITY CLASSES ADICIONALES
   ================================================ */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.relative { position: relative; }
.absolute { position: absolute; }
.sticky { position: sticky; top: 0; z-index: 100; }

.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.gap-1 { gap: 0.25rem; }
.gap-2 { gap: 0.5rem; }
.gap-3 { gap: 0.75rem; }
.gap-4 { gap: 1rem; }

.w-full { width: 100%; }
.h-full { height: 100%; }
.min-w-0 { min-width: 0; }

.opacity-0 { opacity: 0; }
.opacity-50 { opacity: 0.5; }
.opacity-100 { opacity: 1; }

.pointer-events-none { pointer-events: none; }
.cursor-pointer { cursor: pointer; }
.cursor-not-allowed { cursor: not-allowed; }

.overflow-hidden { overflow: hidden; }
.overflow-auto { overflow: auto; }
.overflow-x-auto { overflow-x: auto; }

.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

.font-normal { font-weight: 400; }
.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }
.font-extrabold { font-weight: 800; }

.rounded { border-radius: 8px; }
.rounded-lg { border-radius: 12px; }
.rounded-xl { border-radius: 16px; }
.rounded-2xl { border-radius: 20px; }
.rounded-full { border-radius: 9999px; }

/* Espaciado responsive */
.p-responsive {
  padding: clamp(0.75rem, 2vw, 1.5rem);
}

.m-responsive {
  margin: clamp(0.5rem, 1.5vw, 1rem);
}

.gap-responsive {
  gap: clamp(0.5rem, 1.5vw, 1rem);
}

/* ===========================================
   EXPANDABLE BARBER CUTS SECTIONS
   =========================================== */

.barber-cuts-section {
  margin-bottom: 0.5rem;
}

.list-row--clickable {
  transition: background 0.2s, transform 0.15s;
}

.list-row--clickable:hover {
  background: rgba(var(--gold-rgb), 0.08);
  transform: translateX(4px);
}

.expand-icon {
  color: var(--gold);
  min-width: 1rem;
  text-align: center;
}

.cuts-detail-list {
  animation: slideDown 0.2s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.cut-detail-item {
  transition: background 0.15s, transform 0.1s;
}

.cut-detail-item:hover {
  background: rgba(var(--gold-rgb), 0.1) !important;
  transform: translateX(4px);
}

/* Toast notification for cuts */
.notification-toast--cut {
  border-left-color: var(--success);
}

.notification-toast--cut .notification-toast__icon {
  color: var(--success);
}

/* ===========================================
   ELITE LANDING PAGE - DiseÃ±o Elegante 3.0
   Sistema de BarberÃ­a Premium
   =========================================== */

/* Landing Elite Base */
.landing-elite {
  display: flex;
  flex-direction: column;
  background: #0a0a0f;
  color: #fff;
}

/* Colores */
.text-gold {
  background: linear-gradient(135deg, #d4af37, #f4d03f, #d4af37);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ===== HERO ELITE - Split Layout ===== */
.hero-elite {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 100vh;
  overflow: hidden;
}

.hero-elite__left {
  display: flex;
  align-items: center;
  padding: 4rem;
  background: linear-gradient(135deg, #0a0a0f 0%, #15151f 100%);
}

.hero-elite__content {
  max-width: 540px;
  margin-left: auto;
}

.elite-label {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.6rem 1.25rem;
  background: rgba(212, 175, 55, 0.1);
  border: 1px solid rgba(212, 175, 55, 0.3);
  border-radius: 50px;
  font-size: 0.85rem;
  color: #d4af37;
  margin-bottom: 2rem;
  animation: fadeInUp 0.6s ease;
}

.elite-label__icon {
  font-size: 1rem;
}

.hero-elite__title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 1.5rem;
  animation: fadeInUp 0.6s ease 0.1s both;
}

.hero-elite__text {
  font-size: 1.1rem;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.7;
  margin-bottom: 2.5rem;
  animation: fadeInUp 0.6s ease 0.2s both;
}

.hero-elite__cta {
  display: flex;
  gap: 1rem;
  margin-bottom: 3rem;
  animation: fadeInUp 0.6s ease 0.3s both;
}

/* Botones Elite */
.btn-elite {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  padding: 1rem 2rem;
  font-size: 0.95rem;
  font-weight: 600;
  border-radius: 10px;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
}

.btn-elite svg {
  width: 18px;
  height: 18px;
}

.btn-elite--primary {
  background: linear-gradient(135deg, #d4af37, #f4d03f);
  color: #0a0a0f;
  box-shadow: 0 4px 20px rgba(212, 175, 55, 0.3);
}

.btn-elite--primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 30px rgba(212, 175, 55, 0.4);
}

.btn-elite--ghost {
  background: transparent;
  color: rgba(255, 255, 255, 0.8);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.btn-elite--ghost:hover {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.4);
}

.btn-elite--outline {
  background: transparent;
  color: #d4af37;
  border: 2px solid rgba(212, 175, 55, 0.5);
}

.btn-elite--outline:hover {
  background: rgba(212, 175, 55, 0.1);
  border-color: #d4af37;
}

.btn-elite--sm {
  padding: 0.75rem 1.5rem;
  font-size: 0.9rem;
  background: linear-gradient(135deg, #d4af37, #f4d03f);
  color: #0a0a0f;
}

.btn-elite--lg {
  padding: 1.25rem 2.5rem;
  font-size: 1.05rem;
}

/* MÃ©tricas Hero */
.hero-elite__metrics {
  display: flex;
  align-items: center;
  gap: 2rem;
  animation: fadeInUp 0.6s ease 0.4s both;
}

.metric-elite {
  display: flex;
  flex-direction: column;
}

.metric-elite__value {
  font-family: 'Playfair Display', serif;
  font-size: 2rem;
  font-weight: 700;
  color: #d4af37;
}

.metric-elite__label {
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.5);
}

.metric-elite__divider {
  width: 1px;
  height: 40px;
  background: rgba(255, 255, 255, 0.15);
}

/* Hero Visual */
.hero-elite__right {
  position: relative;
  overflow: hidden;
}

.hero-elite__visual {
  position: relative;
  width: 100%;
  height: 100%;
}

.hero-elite__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(0.9);
}

.hero-elite__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, #0a0a0f 0%, transparent 30%);
}

/* Floating Badges */
.floating-badge {
  position: absolute;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem 1.25rem;
  background: rgba(10, 10, 15, 0.85);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 14px;
  animation: float 4s ease-in-out infinite;
}

.floating-badge--top {
  top: 20%;
  right: 10%;
  animation-delay: 0s;
}

.floating-badge--bottom {
  bottom: 25%;
  left: 5%;
  animation-delay: 1s;
}

.floating-badge__icon {
  font-size: 1.5rem;
}

.floating-badge div strong {
  display: block;
  font-size: 1.1rem;
  color: #fff;
}

.floating-badge div span {
  font-size: 0.8rem;
  color: rgba(255, 255, 255, 0.5);
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== SECCIONES ELITE ===== */
.section-elite {
  padding: 6rem 4rem;
  max-width: 1400px;
  margin: 0 auto;
  width: 100%;
}

.section-elite--dark {
  background: rgba(255, 255, 255, 0.02);
  max-width: 100%;
}

.section-elite--dark > * {
  max-width: 1400px;
  margin-left: auto;
  margin-right: auto;
}

.section-elite__head {
  margin-bottom: 3rem;
}

.section-elite__head--center {
  text-align: center;
}

.section-elite__label {
  display: inline-block;
  padding: 0.5rem 1.25rem;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50px;
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 1rem;
}

.section-elite__label--gold {
  background: rgba(212, 175, 55, 0.15);
  color: #d4af37;
}

.section-elite__title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 4vw, 2.75rem);
  font-weight: 700;
  margin-bottom: 0.5rem;
}

.section-elite__desc {
  font-size: 1.05rem;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 1rem;
}

/* ===== SERVICIOS ELITE ===== */
.services-elite {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.service-elite {
  display: grid;
  grid-template-columns: 60px 60px 1fr auto auto;
  align-items: center;
  gap: 2rem;
  padding: 1.75rem 2rem;
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 16px;
  transition: all 0.3s ease;
}

.service-elite:hover {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(212, 175, 55, 0.3);
  transform: translateX(8px);
}

.service-elite__number {
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem;
  color: rgba(255, 255, 255, 0.2);
  font-weight: 700;
}

.service-elite__icon {
  font-size: 2rem;
}

.service-elite__body h3 {
  font-size: 1.2rem;
  font-weight: 600;
  margin-bottom: 0.25rem;
}

.service-elite__body p {
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.5);
}

.service-elite__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.25rem;
}

.service-elite__price {
  font-size: 1.25rem;
  font-weight: 700;
  color: #d4af37;
}

.service-elite__time {
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.4);
}

.service-elite__btn {
  padding: 0.75rem 1.5rem;
  background: transparent;
  border: 1px solid rgba(212, 175, 55, 0.5);
  color: #d4af37;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.service-elite__btn:hover {
  background: linear-gradient(135deg, #d4af37, #f4d03f);
  color: #0a0a0f;
  border-color: transparent;
}

/* ===== BENTO GRID ===== */
.bento-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: auto auto;
  gap: 1.25rem;
}

.bento-card {
  padding: 2rem;
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20px;
  transition: all 0.3s ease;
}

.bento-card:hover {
  background: rgba(255, 255, 255, 0.04);
  transform: translateY(-4px);
}

.bento-card--large {
  grid-column: span 2;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.bento-card--accent {
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.1) 0%, rgba(212, 175, 55, 0.02) 100%);
  border-color: rgba(212, 175, 55, 0.2);
}

.bento-card__icon {
  font-size: 2rem;
  margin-bottom: 1rem;
}

.bento-card h3 {
  font-size: 1.2rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
}

.bento-card p {
  font-size: 0.95rem;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.6;
}

.bento-card__visual {
  margin-top: 2rem;
}

.mini-calendar {
  display: flex;
  gap: 0.75rem;
}

.mini-calendar__day {
  width: 50px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  font-weight: 600;
  font-size: 1.1rem;
}

.mini-calendar__day--active {
  background: linear-gradient(135deg, #d4af37, #f4d03f);
  color: #0a0a0f;
}

/* ===== MASONRY GALLERY ===== */
.masonry-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: 200px;
  gap: 1rem;
}

.masonry-item {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
}

.masonry-item--tall {
  grid-row: span 2;
}

.masonry-item--wide {
  grid-column: span 2;
}

.masonry-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.masonry-item:hover img {
  transform: scale(1.1);
}

.masonry-tag {
  position: absolute;
  bottom: 1rem;
  left: 1rem;
  padding: 0.5rem 1rem;
  background: rgba(10, 10, 15, 0.8);
  backdrop-filter: blur(10px);
  border-radius: 8px;
  font-size: 0.85rem;
  font-weight: 500;
  opacity: 0;
  transform: translateY(10px);
  transition: all 0.3s ease;
}

.masonry-item:hover .masonry-tag {
  opacity: 1;
  transform: translateY(0);
}

/* ===== TEAM ELITE ===== */
.team-elite {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2rem;
  justify-items: center;
}

.barber-elite {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 2rem;
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24px;
  width: 100%;
  max-width: 320px;
  transition: all 0.3s ease;
}

.barber-elite:hover {
  transform: translateY(-8px);
  border-color: rgba(212, 175, 55, 0.3);
}

.barber-elite__img {
  position: relative;
  width: 160px;
  height: 160px;
  margin-bottom: 1.5rem;
}

.barber-elite__img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
  border: 3px solid rgba(212, 175, 55, 0.3);
}

.barber-elite__online {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.4rem 0.75rem;
  background: rgba(10, 10, 15, 0.9);
  border-radius: 20px;
  font-size: 0.75rem;
  color: #4ade80;
}

.barber-elite__online span {
  width: 6px;
  height: 6px;
  background: #4ade80;
  border-radius: 50%;
}

.barber-elite__info h4 {
  font-size: 1.2rem;
  margin-bottom: 0.25rem;
}

.barber-elite__info span {
  display: block;
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 1.25rem;
}

/* ===== TESTIMONIALS ELITE ===== */
.testimonials-elite {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 2rem;
  margin-bottom: 3rem;
}

.testimonial-elite {
  padding: 2rem;
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20px;
  transition: all 0.3s ease;
}

.testimonial-elite:hover {
  background: rgba(255, 255, 255, 0.04);
}

.testimonial-elite__quote {
  font-family: 'Playfair Display', serif;
  font-size: 4rem;
  color: rgba(212, 175, 55, 0.3);
  line-height: 1;
  margin-bottom: -1rem;
}

.testimonial-elite p {
  font-size: 1rem;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 1rem;
}

.testimonial-elite__rating {
  color: #d4af37;
  font-size: 1rem;
  letter-spacing: 2px;
  margin-bottom: 1rem;
}

.testimonial-elite__author {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.testimonial-elite__author img,
.avatar-initial {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  object-fit: cover;
}

.avatar-initial {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #d4af37, #f4d03f);
  color: #0a0a0f;
  font-weight: 700;
  font-size: 1.1rem;
}

.testimonial-elite__author span {
  font-weight: 500;
}

.testimonials-elite__empty {
  grid-column: 1 / -1;
  text-align: center;
  padding: 4rem 2rem;
  background: rgba(255, 255, 255, 0.02);
  border-radius: 20px;
}

.testimonials-elite__empty span {
  font-size: 3rem;
  display: block;
  margin-bottom: 1rem;
}

.testimonials-elite__empty p {
  color: rgba(255, 255, 255, 0.5);
}

.testimonial-elite__cta {
  text-align: center;
}

/* ===== FORM ELITE ===== */
.form-elite {
  max-width: 560px;
  margin: 0 auto;
  padding: 2.5rem;
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 24px;
}

.form-elite h4 {
  text-align: center;
  font-size: 1.25rem;
  margin-bottom: 1.5rem;
}

.form-elite__row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-bottom: 1rem;
}

.form-elite input,
.form-elite textarea {
  width: 100%;
  padding: 1rem;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12px;
  color: #fff;
  font-size: 1rem;
  transition: all 0.3s ease;
}

.form-elite input:focus,
.form-elite textarea:focus {
  outline: none;
  border-color: #d4af37;
  background: rgba(255, 255, 255, 0.08);
}

.form-elite textarea {
  min-height: 120px;
  resize: vertical;
  margin-bottom: 1rem;
}

.form-elite__rating {
  display: flex;
  justify-content: center;
  gap: 0.5rem;
  margin: 1.5rem 0;
}

.form-elite__rating button {
  background: none;
  border: none;
  font-size: 1.75rem;
  color: rgba(255, 255, 255, 0.2);
  cursor: pointer;
  transition: all 0.2s ease;
}

.form-elite__rating button.active,
.form-elite__rating button:hover {
  color: #d4af37;
  transform: scale(1.2);
}

.form-elite__actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
}

/* ===== CONTACT ELITE ===== */
.contact-elite {
  padding: 4rem 2rem;
  background: rgba(255, 255, 255, 0.02);
}

.contact-elite__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
  max-width: 1200px;
  margin: 0 auto;
}

.contact-elite__card {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  padding: 1.5rem;
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 16px;
  text-align: center;
}

.contact-elite__card span {
  font-size: 2rem;
}

.contact-elite__card strong {
  font-size: 0.95rem;
  color: rgba(255, 255, 255, 0.9);
}

.contact-elite__card p {
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.5);
  margin: 0;
}

/* ===== CTA ELITE ===== */
.cta-elite {
  padding: 6rem 2rem;
  text-align: center;
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.08) 0%, transparent 60%);
}

.cta-elite__inner {
  max-width: 600px;
  margin: 0 auto;
}

.cta-elite h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 4vw, 2.75rem);
  margin-bottom: 1rem;
}

.cta-elite p {
  font-size: 1.1rem;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 2rem;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
  .hero-elite {
    grid-template-columns: 1fr;
    min-height: auto;
  }
  
  .hero-elite__left {
    padding: 6rem 2rem 4rem;
  }
  
  .hero-elite__content {
    max-width: 100%;
    margin: 0 auto;
  }
  
  .hero-elite__right {
    height: 50vh;
  }
  
  .hero-elite__overlay {
    background: linear-gradient(180deg, #0a0a0f 0%, transparent 30%);
  }
  
  .section-elite {
    padding: 4rem 2rem;
  }
  
  .service-elite {
    grid-template-columns: 50px 1fr;
    gap: 1rem;
  }
  
  .service-elite__number,
  .service-elite__icon {
    display: none;
  }
  
  .service-elite__meta {
    grid-column: 2;
    flex-direction: row;
    gap: 1rem;
    margin-top: 0.5rem;
  }
  
  .service-elite__btn {
    grid-column: 2;
    margin-top: 0.75rem;
    width: 100%;
  }
  
  .bento-grid {
    grid-template-columns: 1fr 1fr;
  }
  
  .bento-card--large {
    grid-column: span 2;
  }
  
  .masonry-grid {
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 180px;
  }
  
  .masonry-item--tall {
    grid-row: span 2;
  }
  
  .masonry-item--wide {
    grid-column: span 2;
  }
  
  .contact-elite__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .hero-elite__left {
    padding: 5rem 1.5rem 3rem;
  }
  
  .hero-elite__title {
    font-size: 2rem;
  }
  
  .hero-elite__cta {
    flex-direction: column;
  }
  
  .btn-elite {
    width: 100%;
    justify-content: center;
  }
  
  .hero-elite__metrics {
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  
  .metric-elite__divider {
    display: none;
  }
  
  .hero-elite__right {
    height: 40vh;
  }
  
  .floating-badge {
    display: none;
  }
  
  .service-elite {
    grid-template-columns: 1fr;
    padding: 1.5rem;
  }
  
  .service-elite__body,
  .service-elite__meta,
  .service-elite__btn {
    grid-column: 1;
  }
  
  .bento-grid {
    grid-template-columns: 1fr;
  }
  
  .bento-card--large {
    grid-column: 1;
  }
  
  .masonry-grid {
    grid-template-columns: 1fr;
    grid-auto-rows: 200px;
  }
  
  .masonry-item--tall,
  .masonry-item--wide {
    grid-row: span 1;
    grid-column: 1;
  }
  
  .testimonials-elite {
    grid-template-columns: 1fr;
  }
  
  .form-elite__row {
    grid-template-columns: 1fr;
  }
  
  .contact-elite__grid {
    grid-template-columns: 1fr;
    gap: 1rem;
  }
}

@media (max-width: 480px) {
  .hero-elite__left {
    padding: 4rem 1rem 2rem;
  }
  
  .elite-label {
    font-size: 0.75rem;
    padding: 0.5rem 1rem;
  }
  
  .hero-elite__title {
    font-size: 1.75rem;
  }
  
  .hero-elite__text {
    font-size: 1rem;
  }
  
  .metric-elite__value {
    font-size: 1.5rem;
  }
  
  .section-elite__title {
    font-size: 1.5rem;
  }
  
  .form-elite {
    padding: 1.5rem;
  }
  
  .cta-elite h2 {
    font-size: 1.5rem;
  }
}
/* ==========================================
   ðŸš€ ANIMACIONES AVANZADAS EXTRA
   ========================================== */

/* Efecto de Onda Sonora */
@keyframes sound-wave {
  0% {
    transform: scaleY(0.5);
  }
  50% {
    transform: scaleY(1.5);
  }
  100% {
    transform: scaleY(0.5);
  }
}

.sound-bars {
  display: flex;
  align-items: center;
  gap: 3px;
  height: 30px;
}

.sound-bar {
  width: 4px;
  background: linear-gradient(180deg, var(--gold) 0%, var(--gold-3) 100%);
  border-radius: 2px;
  animation: sound-wave 0.8s ease-in-out infinite;
}

.sound-bar:nth-child(1) { animation-delay: 0s; height: 60%; }
.sound-bar:nth-child(2) { animation-delay: 0.1s; height: 80%; }
.sound-bar:nth-child(3) { animation-delay: 0.2s; height: 100%; }
.sound-bar:nth-child(4) { animation-delay: 0.3s; height: 70%; }
.sound-bar:nth-child(5) { animation-delay: 0.4s; height: 90%; }

/* Efecto Typing */
.typing-effect {
  overflow: hidden;
  border-right: 3px solid var(--gold);
  white-space: nowrap;
  animation: 
    typewriter 4s steps(40) 1s infinite,
    cursor-blink 0.7s step-end infinite;
}

/* Efecto Underline Animado */
.underline-animated {
  position: relative;
  display: inline-block;
}

.underline-animated::after {
  content: '';
  position: absolute;
  width: 0;
  height: 3px;
  bottom: -4px;
  left: 0;
  background: linear-gradient(90deg, var(--gold), var(--gold-2));
  transition: width 0.4s var(--ease-spring);
  border-radius: 2px;
}

.underline-animated:hover::after {
  width: 100%;
}

/* Efecto Magnetic Hover */
.magnetic-hover {
  transition: transform 0.3s var(--ease-smooth);
}

/* Efecto Split Text */
.split-text {
  display: inline-flex;
  overflow: hidden;
}

.split-text span {
  display: inline-block;
  transform: translateY(100%);
  animation: split-reveal 0.6s var(--ease-out-expo) forwards;
}

@keyframes split-reveal {
  to {
    transform: translateY(0);
  }
}

/* Efecto Blur In */
@keyframes blur-in {
  0% {
    opacity: 0;
    filter: blur(20px);
    transform: scale(1.1);
  }
  100% {
    opacity: 1;
    filter: blur(0);
    transform: scale(1);
  }
}

.blur-in {
  animation: blur-in 0.8s var(--ease-out-expo) forwards;
}

/* Efecto Flip Card */
.flip-card {
  perspective: 1000px;
}

.flip-card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transition: transform 0.8s var(--ease-smooth);
  transform-style: preserve-3d;
}

.flip-card:hover .flip-card-inner {
  transform: rotateY(180deg);
}

.flip-card-front,
.flip-card-back {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 20px;
}

.flip-card-back {
  transform: rotateY(180deg);
}

/* Efecto Counter Animado */
@keyframes count-up {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.counter-animated {
  animation: count-up 0.6s var(--ease-out-expo) forwards;
  font-variant-numeric: tabular-nums;
}

/* Efecto de Spotlight */
.spotlight {
  position: relative;
  overflow: hidden;
}

.spotlight::before {
  content: '';
  position: absolute;
  top: 0;
  left: -150%;
  width: 150%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(0, 212, 255, 0.15) 50%,
    transparent 100%
  );
  transform: skewX(-20deg);
  animation: spotlight-sweep 5s ease-in-out infinite;
}

@keyframes spotlight-sweep {
  0%, 100% {
    left: -150%;
  }
  50% {
    left: 150%;
  }
}

/* Efecto de Confetti */
.confetti-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  overflow: hidden;
  z-index: 9999;
}

.confetti {
  position: absolute;
  width: 10px;
  height: 10px;
  animation: confetti-fall 3s ease-in-out forwards;
}

@keyframes confetti-fall {
  0% {
    transform: translateY(-100vh) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(100vh) rotate(720deg);
    opacity: 0;
  }
}

/* Efecto Parallax Suave */
.parallax-container {
  overflow: hidden;
  position: relative;
}

.parallax-layer {
  will-change: transform;
  transition: transform 0.1s linear;
}

/* Efecto de Tarjeta 3D */
.card-3d {
  transform-style: preserve-3d;
  perspective: 1000px;
  transition: transform 0.6s var(--ease-smooth);
}

.card-3d:hover {
  transform: rotateY(10deg) rotateX(5deg);
}

.card-3d-content {
  transform: translateZ(30px);
  transition: transform 0.4s var(--ease-smooth);
}

.card-3d:hover .card-3d-content {
  transform: translateZ(50px);
}

/* Efecto Marquee */
.marquee {
  overflow: hidden;
  white-space: nowrap;
}

.marquee-content {
  display: inline-block;
  animation: marquee 20s linear infinite;
}

@keyframes marquee {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}

/* Efecto Grain/Noise de Fondo */
.grain-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  opacity: 0.03;
  z-index: 9998;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
}

/* Efecto de LÃ­neas de Velocidad */
@keyframes speed-lines {
  0% {
    transform: translateX(-100%);
    opacity: 0;
  }
  50% {
    opacity: 1;
  }
  100% {
    transform: translateX(100%);
    opacity: 0;
  }
}

.speed-lines {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.speed-line {
  position: absolute;
  width: 200px;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  animation: speed-lines 2s linear infinite;
}

/* Efecto de NÃºmeros Incrementales */
.number-increment {
  font-variant-numeric: tabular-nums;
  font-feature-settings: "tnum";
}

/* ==========================================
   ðŸŽ† EFECTOS DE PARTÃCULAS
   ========================================== */
.particles-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: -1;
  overflow: hidden;
}

.particle {
  position: absolute;
  width: 4px;
  height: 4px;
  background: var(--gold);
  border-radius: 50%;
  opacity: 0.3;
  animation: particle-drift 15s linear infinite;
}

@keyframes particle-drift {
  0% {
    transform: translateY(100vh) translateX(0) scale(0);
    opacity: 0;
  }
  10% {
    opacity: 0.5;
    transform: scale(1);
  }
  90% {
    opacity: 0.5;
  }
  100% {
    transform: translateY(-20vh) translateX(50px) scale(0);
    opacity: 0;
  }
}

/* ==========================================
   ðŸŽ¨ DEGRADADOS PREMIUM ADICIONALES
   ========================================== */
.gradient-gold {
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold-2) 50%, var(--gold-3) 100%);
}

.gradient-mesh {
  background: 
    radial-gradient(at 40% 20%, rgba(0, 212, 255, 0.3) 0px, transparent 50%),
    radial-gradient(at 80% 0%, rgba(96, 165, 250, 0.2) 0px, transparent 50%),
    radial-gradient(at 0% 50%, rgba(167, 139, 250, 0.2) 0px, transparent 50%),
    radial-gradient(at 80% 50%, rgba(251, 113, 133, 0.15) 0px, transparent 50%),
    radial-gradient(at 0% 100%, rgba(74, 222, 128, 0.15) 0px, transparent 50%);
}

.gradient-conic {
  background: conic-gradient(from 0deg, var(--gold), var(--gold-2), var(--gold-3), var(--gold));
}

/* ==========================================
   ðŸ“ BORDES DECORATIVOS
   ========================================== */
.border-gradient {
  border: 2px solid transparent;
  background: 
    linear-gradient(var(--bg-card), var(--bg-card)) padding-box,
    linear-gradient(135deg, var(--gold), var(--gold-3)) border-box;
}

.border-animated {
  position: relative;
}

.border-animated::before {
  content: '';
  position: absolute;
  inset: -2px;
  background: linear-gradient(90deg, var(--gold), var(--gold-2), var(--gold-3), var(--gold));
  background-size: 300% 100%;
  animation: border-flow 3s linear infinite;
  border-radius: inherit;
  z-index: -1;
}

@keyframes border-flow {
  0% { background-position: 0% 50%; }
  100% { background-position: 300% 50%; }
}

/* ==========================================
   ðŸ–±ï¸ CURSOR PERSONALIZADO
   ========================================== */
.custom-cursor {
  cursor: none;
}

.cursor-dot {
  width: 8px;
  height: 8px;
  background: var(--gold);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 99999;
  transition: transform 0.1s ease;
}

.cursor-ring {
  width: 40px;
  height: 40px;
  border: 2px solid var(--gold);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 99998;
  transition: transform 0.3s ease, width 0.3s ease, height 0.3s ease;
  transform: translate(-50%, -50%);
}

.cursor-ring.hover {
  width: 60px;
  height: 60px;
  border-color: var(--gold-2);
}

/* ==========================================
   ðŸŽµ MICRO-INTERACCIONES
   ========================================== */
.tap-highlight {
  -webkit-tap-highlight-color: rgba(0, 212, 255, 0.2);
}

.touch-feedback:active {
  transform: scale(0.95);
  transition: transform 0.1s ease;
}

/* Efecto de PresiÃ³n */
.pressure-effect {
  transition: transform 0.2s var(--ease-spring), box-shadow 0.2s ease;
}

.pressure-effect:active {
  transform: scale(0.97);
  box-shadow: inset 0 3px 10px rgba(0, 0, 0, 0.2);
}

/* ==========================================
   ðŸŒŸ TOOLTIPS ANIMADOS
   ========================================== */
.tooltip-premium {
  position: relative;
}

.tooltip-premium::before {
  content: attr(data-tooltip);
  position: absolute;
  bottom: calc(100% + 10px);
  left: 50%;
  transform: translateX(-50%) translateY(10px);
  padding: 0.75rem 1rem;
  background: var(--bg-card);
  color: var(--text-primary);
  font-size: 0.85rem;
  border-radius: 12px;
  white-space: nowrap;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s var(--ease-spring);
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  border: 1px solid var(--border-gold);
  z-index: 1000;
}

.tooltip-premium::after {
  content: '';
  position: absolute;
  bottom: calc(100% + 2px);
  left: 50%;
  transform: translateX(-50%);
  border: 8px solid transparent;
  border-top-color: var(--bg-card);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s var(--ease-spring);
}

.tooltip-premium:hover::before,
.tooltip-premium:hover::after {
  opacity: 1;
  visibility: visible;
  transform: translateX(-50%) translateY(0);
}

/* ==========================================
   ðŸŽŠ NOTIFICACIONES TOAST
   ========================================== */
.toast {
  position: fixed;
  bottom: 2rem;
  right: 2rem;
  padding: 1rem 1.5rem;
  background: var(--bg-card);
  border: 1px solid var(--border-gold);
  border-radius: 16px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  gap: 1rem;
  animation: toast-in 0.5s var(--ease-spring);
  z-index: 10000;
}

@keyframes toast-in {
  from {
    opacity: 0;
    transform: translateY(20px) scale(0.9);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.toast-out {
  animation: toast-out 0.4s var(--ease-smooth) forwards;
}

@keyframes toast-out {
  to {
    opacity: 0;
    transform: translateX(100px);
  }
}

/* ==========================================
   ðŸ“± RESPONSIVE FINAL TOUCHES
   ========================================== */
@media (max-width: 768px) {
  .glass-card {
    border-radius: 16px;
    backdrop-filter: blur(10px);
  }
  
  .btn-premium {
    padding: 0.875rem 1.5rem;
    font-size: 0.9rem;
  }
  
  .gold-card {
    padding: 1.5rem;
    border-radius: 16px;
  }
  
  .toast {
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
  }
}

@media (max-width: 480px) {
  :root {
    font-size: 14px;
  }
  
  .glass-card {
    border-radius: 12px;
  }
  
  .btn-premium {
    padding: 0.75rem 1.25rem;
    font-size: 0.85rem;
    border-radius: 40px;
  }
  
  .input-premium {
    padding: 0.875rem 1.25rem;
    border-radius: 12px;
  }
  
  .gold-card {
    padding: 1.25rem;
  }
}

/* ==========================================
   ðŸŽ¯ PRINT STYLES
   ========================================== */
@media print {
  body {
    background: white;
    color: black;
  }
  
  .no-print {
    display: none !important;
  }
  
  .glass-card,
  .gold-card {
    background: white;
    border: 1px solid #ccc;
    box-shadow: none;
  }
}

/* ==========================================
   â™¿ ACCESIBILIDAD MEJORADA
   ========================================== */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
  
  .animate-float,
  .animate-glow,
  .animate-shimmer,
  .animate-heartbeat,
  .animate-bounce {
    animation: none !important;
  }
}

@media (prefers-contrast: high) {
  :root {
    --gold: #ffcc00;
    --text-primary: #ffffff;
    --bg-primary: #000000;
  }
  
  .glass-card,
  .gold-card {
    border-width: 2px;
  }
}

/* ==========================================
   ðŸŒ™ DARK MODE REFINEMENTS
   ========================================== */
@media (prefers-color-scheme: dark) {
  :root {
    color-scheme: dark;
  }
}

/* ==========================================
   âœ… FIN DEL SISTEMA DE DISEÃ‘O BARBADOS ELITE
   Total: Animaciones 50+ | Componentes 40+ | 100% Responsive
   ========================================== */

/* ==========================================
   EFECTOS INTERACTIVOS ADICIONALES CYBER
   ========================================== */

/* Efecto Hover 3D para Tarjetas */
.card-3d-tilt {
  transform-style: preserve-3d;
  perspective: 1000px;
}

.card-3d-tilt:hover {
  transform: rotateY(5deg) rotateX(-3deg) translateZ(10px);
}

/* Efecto Glow Border Animado */
.glow-border {
  position: relative;
}

.glow-border::before {
  content: '';
  position: absolute;
  inset: -3px;
  background: linear-gradient(45deg, #00d4ff, #8338ec, #ff006e, #00f5d4, #00d4ff);
  background-size: 400% 400%;
  border-radius: inherit;
  z-index: -1;
  animation: glow-rotate 6s linear infinite;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.glow-border:hover::before {
  opacity: 1;
}

@keyframes glow-rotate {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* Icono con Rotacion al Hover */
.icon-spin:hover {
  animation: icon-spin 0.6s var(--ease-bounce);
}

@keyframes icon-spin {
  0% { transform: rotate(0deg) scale(1); }
  25% { transform: rotate(-15deg) scale(1.1); }
  75% { transform: rotate(15deg) scale(1.1); }
  100% { transform: rotate(0deg) scale(1); }
}

/* Links con Subrayado Animado */
.link-underline {
  position: relative;
  text-decoration: none;
}

.link-underline::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--gradient-main);
  transition: width 0.4s var(--ease-spring);
}

.link-underline:hover::after {
  width: 100%;
}

/* Efecto de Texto Brillante */
.text-shine {
  background: linear-gradient(90deg, #fff, #00d4ff, #fff);
  background-size: 200% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: text-shine-anim 3s linear infinite;
}

@keyframes text-shine-anim {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* Efecto de Ondas al Click */
.click-ripple {
  position: relative;
  overflow: hidden;
}

/* Badge Pulsante */
.badge-pulse {
  position: relative;
}

.badge-pulse::after {
  content: '';
  position: absolute;
  inset: -4px;
  border-radius: inherit;
  border: 2px solid currentColor;
  opacity: 0;
  animation: badge-pulse-anim 2s ease-in-out infinite;
}

@keyframes badge-pulse-anim {
  0%, 100% {
    transform: scale(1);
    opacity: 0;
  }
  50% {
    transform: scale(1.2);
    opacity: 0.5;
  }
}

/* Estadisticas con Contador Animado */
.stat-counter {
  font-variant-numeric: tabular-nums;
  animation: stat-pop 0.5s var(--ease-spring);
}

@keyframes stat-pop {
  0% {
    transform: scale(0.5);
    opacity: 0;
  }
  60% {
    transform: scale(1.1);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* Efecto de Carga de Imagen */
.img-loading {
  background: linear-gradient(90deg, #12121f 25%, #1a1a2e 50%, #12121f 75%);
  background-size: 200% 100%;
  animation: img-skeleton 1.5s ease-in-out infinite;
}

@keyframes img-skeleton {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* Animacion de Entrada Escalonada */
.stagger-1 { animation-delay: 0.05s; }
.stagger-2 { animation-delay: 0.1s; }
.stagger-3 { animation-delay: 0.15s; }
.stagger-4 { animation-delay: 0.2s; }
.stagger-5 { animation-delay: 0.25s; }
.stagger-6 { animation-delay: 0.3s; }
.stagger-7 { animation-delay: 0.35s; }
.stagger-8 { animation-delay: 0.4s; }

/* Navbar Sticky con Blur */
.navbar-sticky {
  position: sticky;
  top: 1rem;
  z-index: 1000;
  transition: all 0.4s var(--ease-smooth);
}

.navbar-sticky.scrolled {
  background: rgba(10, 10, 18, 0.95) !important;
  backdrop-filter: blur(30px) saturate(200%);
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5), 0 0 60px rgba(0, 212, 255, 0.1);
}

/* FIN DEL SISTEMA BARBADOS CYBER */
