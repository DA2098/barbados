@import "tailwindcss";

/* Animaciones modernas */
@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-12px); }
}

@keyframes glow-pulse {
  0%, 100% { box-shadow: 0 0 20px rgba(244, 199, 107, 0.3), var(--shadow); }
  50% { box-shadow: 0 0 40px rgba(244, 199, 107, 0.6), var(--shadow); }
}

@keyframes slide-in {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scale-in {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes shimmer {
  0% { background-position: -1000px 0; }
  100% { background-position: 1000px 0; }
}

@keyframes gradient-shift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

:root {
  color-scheme: dark;
  --bg: #08101d;
  --bg-2: #0f172a;
  --panel: rgba(15, 23, 42, 0.88);
  --panel-2: rgba(15, 23, 42, 0.95);
  --line: rgba(255, 255, 255, 0.08);
  --line-2: rgba(255, 255, 255, 0.14);
  --text: #eef2ff;
  --muted: #9fb0d0;
  --gold: #f4c76b;
  --gold-2: #b67f17;
  --green: #4ade80;
  --blue: #60a5fa;
  --red: #fb7185;
  --amber: #fbbf24;
  --shadow: 0 24px 60px rgba(2, 6, 23, 0.35);
}

* {
  box-sizing: border-box;
}

html,
body,
#root {
  min-height: 100%;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  background:
    radial-gradient(circle at top left, rgba(244, 199, 107, 0.18), transparent 24%),
    radial-gradient(circle at 80% 0%, rgba(96, 165, 250, 0.18), transparent 24%),
    radial-gradient(circle at 50% 100%, rgba(74, 222, 128, 0.08), transparent 26%),
    linear-gradient(180deg, #07101c 0%, #0a1222 45%, #08101d 100%);
  color: var(--text);
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

img {
  display: block;
  max-width: 100%;
}

button,
input,
select,
textarea {
  font: inherit;
}

button {
  cursor: pointer;
}

.site-shell {
  min-height: 100vh;
  padding: 1.25rem;
}

.site-header,
.panel,
.auth-card,
.auth-side-card,
.hero-section,
.hero-panel,
.hero-stat,
.landing-card,
.kpi-card,
.entity-card,
.shop-card,
.profile-card,
.conversation-item,
.message-bubble,
.composer-card,
.attachment-chip,
.list-row,
.cart-row,
.mini-stat,
.alert,
.nav-button,
.status-chip,
.empty-state,
.checkout-card,
.coverage-item,
.auth-card--center {
  border: 1px solid var(--line);
  background: var(--panel);
  box-shadow: var(--shadow);
}

.site-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.25rem;
  border-radius: 28px;
  padding: 1rem 1.2rem;
  backdrop-filter: blur(16px);
}

.site-brand {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.brand-mark {
  display: grid;
  height: 60px;
  width: 60px;
  place-items: center;
  border-radius: 18px;
  background: linear-gradient(135deg, var(--gold), var(--gold-2));
  color: #1a1306;
  font-size: 1.7rem;
  font-weight: 800;
}

.site-brand h1,
.hero-copy h2,
.auth-card h1,
.auth-card h2,
.auth-side-card h2 {
  margin: 0.18rem 0 0;
  letter-spacing: -0.04em;
}

.site-brand h1 {
  font-size: 1.35rem;
}

.eyebrow,
.kpi-title,
.metric-label {
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #f9ddb0;
}

.site-nav {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: flex-end;
  gap: 0.55rem;
}

.nav-link,
.button,
.input,
.select,
.textarea,
.badge,
.nav-button {
  border-radius: 16px;
}

.nav-link {
  border: 1px solid transparent;
  background: rgba(255, 255, 255, 0.03);
  padding: 0.72rem 0.95rem;
  color: var(--muted);
  transition: 0.2s ease;
}

.nav-link:hover,
.nav-link--active {
  border-color: rgba(244, 199, 107, 0.35);
  background: rgba(244, 199, 107, 0.12);
  color: var(--text);
}

.alert {
  margin-bottom: 1rem;
  border-radius: 20px;
  padding: 0.9rem 1rem;
}

.alert--danger {
  background: rgba(251, 113, 133, 0.12);
  color: #ffd6de;
}

.alert--success {
  background: rgba(74, 222, 128, 0.12);
  color: #d0fade;
}

.landing-shell,
.content-shell {
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
}

.hero-section {
  display: grid;
  gap: 1.2rem;
  grid-template-columns: 1.5fr 0.9fr;
  border-radius: 34px;
  padding: 1.5rem;
  background:
    radial-gradient(circle at top right, rgba(96, 165, 250, 0.16), transparent 32%),
    radial-gradient(circle at bottom left, rgba(244, 199, 107, 0.14), transparent 28%),
    linear-gradient(180deg, rgba(15, 23, 42, 0.97), rgba(8, 16, 29, 0.97));
}

.hero-section--dynamic {
  position: relative;
  overflow: hidden;
}

.hero-section--dynamic::before,
.hero-section--dynamic::after {
  content: "";
  position: absolute;
  border-radius: 999px;
  filter: blur(40px);
  opacity: 0.34;
  pointer-events: none;
}

.hero-section--dynamic::before {
  top: -70px;
  right: -40px;
  height: 220px;
  width: 220px;
  background: rgba(96, 165, 250, 0.28);
}

.hero-section--dynamic::after {
  bottom: -70px;
  left: -40px;
  height: 220px;
  width: 220px;
  background: rgba(244, 199, 107, 0.22);
}

.hero-copy p,
.auth-card p,
.auth-side-card p,
.panel-subtitle,
.entity-card p,
.shop-body p,
.coverage-item p,
.list-row-main span,
.list-row-main small,
.profile-card span,
.profile-card small,
.mini-stat span,
.empty-state span,
.hero-stat span {
  color: var(--muted);
}

.hero-copy h2 {
  font-size: clamp(2rem, 4vw, 3.6rem);
  max-width: 720px;
  animation: slide-in 0.8s ease-out 0.1s backwards;
}

.hero-copy p {
  max-width: 760px;
  font-size: 1.05rem;
  line-height: 1.7;
  animation: slide-in 0.8s ease-out 0.2s backwards;
}

.hero-actions,
.actions-inline,
.site-nav,
.field-actions,
.top-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.7rem;
}

.hero-panel {
  display: grid;
  gap: 1rem;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  border-radius: 30px;
  padding: 1rem;
}

.hero-showcase {
  display: grid;
  gap: 1rem;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.showcase-card,
.hero-pill,
.premium-strip__item,
.entity-chip {
  border: 1px solid var(--line);
  background: rgba(255, 255, 255, 0.04);
  box-shadow: var(--shadow);
}

.showcase-card {
  position: relative;
  overflow: hidden;
  display: flex;
  min-height: 200px;
  flex-direction: column;
  justify-content: space-between;
  gap: 0.5rem;
  border-radius: 26px;
  padding: 1rem;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  animation: slide-in 0.6s ease forwards;
}

.showcase-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(15, 23, 42, 0.72), rgba(15, 23, 42, 0.48));
  backdrop-filter: blur(4px);
  z-index: 1;
  pointer-events: none;
}

.showcase-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  filter: brightness(0.8) saturate(1.1) contrast(1.1);
  z-index: 0;
}

.showcase-card > span,
.showcase-card > strong,
.showcase-card > small {
  position: relative;
  z-index: 2;
}

.showcase-card:hover {
  transform: translateY(-8px) scale(1.02);
  border-color: rgba(244, 199, 107, 0.4);
  box-shadow: 0 20px 50px rgba(244, 199, 107, 0.15), var(--shadow);
}

.showcase-card:hover .showcase-image {
  filter: brightness(0.9) saturate(1.2) contrast(1.15);
  transform: scale(1.05);
}

.showcase-card strong {
  font-size: 1.8rem;
  font-weight: 800;
}

.showcase-card small {
  color: var(--muted);
}

.showcase-card--primary {
  background: linear-gradient(135deg, rgba(244, 199, 107, 0.22), rgba(182, 127, 23, 0.14));
}

.showcase-card--accent {
  background: linear-gradient(135deg, rgba(96, 165, 250, 0.2), rgba(59, 130, 246, 0.12));
}

.hero-inline-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-top: 1rem;
  animation: slide-in 0.8s ease-out 0.3s backwards;
}

.hero-pill {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  border-radius: 18px;
  padding: 0.8rem 0.95rem;
  transition: all 0.3s ease;
  animation: scale-in 0.5s ease-out;
}

.hero-pill:hover {
  transform: translateY(-4px);
  border-color: rgba(244, 199, 107, 0.3);
  background: rgba(244, 199, 107, 0.08);
}

.hero-pill span,
.showcase-card span {
  color: var(--muted);
}

.hero-pill strong {
  font-size: 1rem;
}

.premium-strip {
  display: grid;
  gap: 1rem;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  animation: slide-in 0.8s ease-out;
}

.premium-strip__item {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.premium-strip__item {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  border-radius: 22px;
  padding: 1rem;
}

.premium-strip__item:hover {
  transform: translateY(-6px);
  border-color: rgba(244, 199, 107, 0.3);
  background: rgba(244, 199, 107, 0.08);
}

.premium-strip__item span {
  color: var(--muted);
}

.landing-grid--featured {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.cards-grid--showcase {
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
}

.entity-card--interactive {
  position: relative;
  overflow: visible;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  animation: scale-in 0.5s ease-out;
}

.entity-card--interactive::after {
  content: "";
  position: absolute;
  inset: auto -40% -60% auto;
  height: 140px;
  width: 140px;
  border-radius: 999px;
  background: radial-gradient(circle, rgba(244, 199, 107, 0.12), transparent);
  filter: blur(32px);
  transition: all 0.4s ease;
  opacity: 0;
}

.entity-card--interactive:hover {
  transform: translateY(-8px) scale(1.03);
  border-color: rgba(244, 199, 107, 0.3);
  box-shadow: 0 20px 40px rgba(244, 199, 107, 0.1), var(--shadow);
}

.entity-card--interactive:hover::after {
  opacity: 1;
  inset: auto -20% -20% auto;
}

.entity-card--glow {
  background: linear-gradient(135deg, rgba(244, 199, 107, 0.15), rgba(96, 165, 250, 0.08));
  border: 1px solid rgba(244, 199, 107, 0.2);
  animation: glow-pulse 3s ease-in-out infinite;
}

.entity-chip {
  display: inline-flex;
  width: fit-content;
  border-radius: 999px;
  padding: 0.38rem 0.75rem;
  font-size: 0.72rem;
  font-weight: 800;
  color: #ffeab0;
}

.entity-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
}

.coverage-grid--premium {
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
}

.coverage-item--premium {
  min-height: 110px;
  border-radius: 24px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.03));
}

.hero-stat,
.kpi-card,
.mini-stat {
  border-radius: 24px;
  padding: 1rem;
}

.mini-stats--dynamic .mini-stat {
  position: relative;
  overflow: hidden;
}

.mini-stats--dynamic .mini-stat small {
  color: var(--muted);
}

.mini-stat--accent {
  background: linear-gradient(135deg, rgba(244, 199, 107, 0.16), rgba(255, 255, 255, 0.03));
}

.mini-stat--success {
  background: linear-gradient(135deg, rgba(74, 222, 128, 0.16), rgba(255, 255, 255, 0.03));
  border: 1px solid rgba(74, 222, 128, 0.15);
}

.mini-stat--info {
  background: linear-gradient(135deg, rgba(96, 165, 250, 0.16), rgba(255, 255, 255, 0.03));
  border: 1px solid rgba(96, 165, 250, 0.15);
}

.mini-stat--warning {
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.16), rgba(255, 255, 255, 0.03));
  border: 1px solid rgba(251, 191, 36, 0.15);
}

.mini-stat--accent {
  background: linear-gradient(135deg, rgba(244, 199, 107, 0.16), rgba(255, 255, 255, 0.03));
  border: 1px solid rgba(244, 199, 107, 0.15);
}

.kpi-card {
  position: relative;
  overflow: hidden;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  animation: slide-in 0.6s ease forwards;
}

.kpi-card::before {
  content: "";
  position: absolute;
  top: -100%;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), transparent);
  transition: top 0.6s ease;
}

.kpi-card:hover {
  transform: translateY(-8px) scale(1.02);
  border-color: rgba(244, 199, 107, 0.35);
  box-shadow: 0 16px 40px rgba(244, 199, 107, 0.12), var(--shadow);
}

.kpi-card:hover::before {
  top: 0;
}

.hero-stat strong,
.kpi-value,
.mini-stat strong {
  display: block;
  margin-top: 0.35rem;
  font-size: 1.55rem;
  font-weight: 800;
}

.landing-grid,
.dashboard-grid,
.kpi-grid,
.cards-grid,
.coverage-grid,
.auth-layout-grid,
.dashboard-shell,
.chat-layout,
.form-grid,
.mini-stats {
  display: grid;
  gap: 1rem;
}

.landing-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.dashboard-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.dashboard-grid--full,
.panel--full {
  grid-column: 1 / -1;
}

.kpi-grid,
.mini-stats {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.cards-grid,
.coverage-grid {
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.auth-layout-grid {
  grid-template-columns: 1.1fr 0.9fr;
}

.panel,
.auth-card,
.auth-side-card,
.landing-card {
  border-radius: 28px;
  padding: 1.2rem;
  animation: slide-in 0.6s ease-out;
}

.landing-card {
  transition: all 0.3s ease;
}

.landing-card:hover {
  border-color: rgba(244, 199, 107, 0.15);
  box-shadow: 0 12px 40px rgba(244, 199, 107, 0.08), var(--shadow);
}

.auth-card,
.auth-side-card {
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
  min-width: min(100%, 560px);
}

.auth-card--center {
  text-align: center;
  border-radius: 28px;
  padding: 2rem;
}

.page-shell-auth {
  display: flex;
  min-height: calc(100vh - 140px);
  align-items: center;
  justify-content: center;
  padding: 1rem 0;
}

.input,
.select,
.textarea {
  width: 100%;
  border: 1px solid var(--line-2);
  background: rgba(255, 255, 255, 0.04);
  padding: 0.9rem 1rem;
  color: var(--text);
  outline: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border-radius: 14px;
}

.input::placeholder,
.textarea::placeholder {
  color: rgba(159, 176, 208, 0.5);
}

.input:hover,
.select:hover,
.textarea:hover {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(244, 199, 107, 0.2);
}

.input:focus,
.select:focus,
.textarea:focus {
  border-color: rgba(244, 199, 107, 0.6);
  background: rgba(255, 255, 255, 0.08);
  box-shadow: 0 0 0 4px rgba(244, 199, 107, 0.12), inset 0 0 0 1px rgba(244, 199, 107, 0.1);
}

.textarea {
  min-height: 120px;
  resize: vertical;
}

.button {
  border: 1px solid transparent;
  padding: 0.8rem 1rem;
  color: var(--text);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  font-weight: 600;
  letter-spacing: 0.5px;
}

.button::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.1);
  transition: left 0.3s ease;
  z-index: -1;
}

.button:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
}

.button:hover::before {
  left: 100%;
}

.button:active {
  transform: translateY(-1px);
}

.button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

.button--primary {
  background: linear-gradient(135deg, var(--gold), var(--gold-2));
  color: #1b1407;
  font-weight: 800;
  box-shadow: 0 8px 24px rgba(244, 199, 107, 0.25);
}

.button--primary:hover {
  box-shadow: 0 12px 36px rgba(244, 199, 107, 0.4);
  filter: brightness(1.1);
}

.button--ghost {
  border-color: var(--line-2);
  background: rgba(255, 255, 255, 0.05);
}

.button--ghost:hover {
  border-color: rgba(244, 199, 107, 0.4);
  background: rgba(244, 199, 107, 0.1);
}

.button--small {
  padding: 0.58rem 0.72rem;
  font-size: 0.88rem;
}

.button--danger {
  background: rgba(251, 113, 133, 0.14);
  color: #ffd5dd;
  border-color: rgba(251, 113, 133, 0.2);
}

.button--danger:hover {
  background: rgba(251, 113, 133, 0.2);
  border-color: rgba(251, 113, 133, 0.4);
}

.button--success {
  background: rgba(74, 222, 128, 0.14);
  color: #d0fade;
  border-color: rgba(74, 222, 128, 0.2);
}

.button--success:hover {
  background: rgba(74, 222, 128, 0.2);
  border-color: rgba(74, 222, 128, 0.4);
}

.button--warning {
  background: rgba(251, 191, 36, 0.16);
  color: #ffefc2;
  border-color: rgba(251, 191, 36, 0.2);
}

.button--warning:hover {
  background: rgba(251, 191, 36, 0.24);
  border-color: rgba(251, 191, 36, 0.4);
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.35rem 0.7rem;
  font-size: 0.75rem;
  font-weight: 700;
}

.badge--info {
  background: rgba(96, 165, 250, 0.14);
  color: #d7eaff;
}

.badge--success {
  background: rgba(74, 222, 128, 0.14);
  color: #d0fade;
}

.badge--warning {
  background: rgba(251, 191, 36, 0.14);
  color: #ffeab0;
}

.badge--danger {
  background: rgba(251, 113, 133, 0.14);
  color: #ffd5dd;
}

.panel-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1rem;
}

.panel-title {
  margin: 0;
  font-size: 1.1rem;
  font-weight: 800;
  letter-spacing: -0.03em;
}

.panel-subtitle {
  margin: 0.3rem 0 0;
  max-width: 720px;
}

.entity-card,
.shop-card,
.coverage-item,
.empty-state,
.checkout-card {
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
  border-radius: 24px;
  padding: 1rem;
}

.entity-card__header,
.shop-meta,
.checkout-line,
.cart-row,
.list-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
}

.shop-card {
  overflow: hidden;
  padding: 0;
  display: flex;
  flex-direction: column;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  animation: scale-in 0.5s ease-out;
}

.shop-card--interactive {
  cursor: pointer;
}

.shop-card--interactive:hover {
  transform: translateY(-12px) scale(1.02);
  border-color: rgba(244, 199, 107, 0.35);
  box-shadow: 0 24px 48px rgba(244, 199, 107, 0.12), var(--shadow);
}

.shop-image-wrapper {
  position: relative;
  overflow: hidden;
  aspect-ratio: 1 / 1;
  width: 100%;
  background: linear-gradient(135deg, rgba(244, 199, 107, 0.1), rgba(96, 165, 250, 0.1));
}

.shop-thumb {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.shop-card--interactive:hover .shop-thumb {
  transform: scale(1.1);
}

.shop-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(15, 23, 42, 0.85), rgba(15, 23, 42, 0.65));
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  opacity: 0;
  transition: opacity 0.3s ease;
  backdrop-filter: blur(4px);
  padding: 1rem;
}

.shop-card--interactive:hover .shop-overlay {
  opacity: 1;
}

.shop-body {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 0.85rem;
  padding: 1.2rem;
  background: var(--panel);
}

.shop-category {
  font-size: 0.85rem;
  color: var(--muted);
  margin: 0.2rem 0 0 0;
}

.shop-description {
  font-size: 0.95rem;
  line-height: 1.5;
  color: var(--muted);
  flex-grow: 1;
}

.shop-price {
  font-size: 1.6rem;
  color: var(--gold);
  font-weight: 800;
}

.button--large {
  padding: 1rem 1.5rem;
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: 0.5px;
}

.dashboard-shell {
  grid-template-columns: 280px 1fr;
}

.dashboard-sidebar {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
  border-radius: 28px;
  padding: 1.2rem;
  text-align: center;
}

.avatar {
  height: 48px;
  width: 48px;
  border-radius: 16px;
  object-fit: cover;
}

.avatar--large {
  height: 88px;
  width: 88px;
  border-radius: 24px;
}

.nav-list {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}

.nav-button {
  padding: 0.9rem 1rem;
  color: var(--text);
  text-align: left;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border-radius: 14px;
  position: relative;
  overflow: hidden;
}

.nav-button::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: 0;
  background: rgba(244, 199, 107, 0.1);
  transition: width 0.3s ease;
  border-radius: 14px;
  z-index: -1;
}

.nav-button:hover,
.nav-button--active {
  color: var(--gold);
  border-color: rgba(244, 199, 107, 0.28);
  background: rgba(244, 199, 107, 0.12);
}

.nav-button:hover::before,
.nav-button--active::before {
  width: 100%;
}

.dashboard-content {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.metric-bars {
  display: grid;
  align-items: end;
  gap: 0.8rem;
  grid-template-columns: repeat(12, minmax(0, 1fr));
  min-height: 220px;
}

.metric-bars--condensed {
  min-height: 210px;
}

.metric-column {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
}

.metric-track {
  display: flex;
  height: 150px;
  width: 100%;
  align-items: end;
  overflow: hidden;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.05);
}

.metric-fill {
  width: 100%;
  height: var(--size);
  border-radius: 999px;
  background: linear-gradient(180deg, var(--gold), var(--gold-2));
}

.metric-amount {
  font-size: 0.72rem;
  color: var(--muted);
  writing-mode: vertical-rl;
  text-orientation: mixed;
}

.table-wrap {
  overflow-x: auto;
}

.table {
  width: 100%;
  border-collapse: collapse;
}

.table th,
.table td {
  border-bottom: 1px solid var(--line);
  padding: 0.9rem 0.75rem;
  text-align: left;
  vertical-align: top;
}

.table th {
  color: #f9ddb0;
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.data-list {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}

.list-row,
.cart-row,
.conversation-item,
.composer-card,
.attachment-chip,
.empty-state,
.checkout-card,
.message-bubble {
  border-radius: 22px;
  padding: 0.95rem 1rem;
}

.chat-layout {
  grid-template-columns: 290px 1fr;
}

.chat-sidebar,
.chat-main {
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
}

.chat-sidebar {
  min-height: 620px;
}

.chat-main {
  min-height: 620px;
}

.conversation-item {
  width: 100%;
  text-align: left;
  color: var(--text);
  background: rgba(255, 255, 255, 0.04);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
  border-radius: 14px;
  position: relative;
  overflow: hidden;
}

.conversation-item::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: 0;
  background: rgba(244, 199, 107, 0.08);
  transition: width 0.3s ease;
  z-index: -1;
}

.conversation-item:hover {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(244, 199, 107, 0.2);
}

.conversation-item:hover::before {
  width: 100%;
}

.conversation-item--active {
  border-color: rgba(244, 199, 107, 0.36);
  background: linear-gradient(90deg, rgba(244, 199, 107, 0.12), rgba(244, 199, 107, 0.05));
  box-shadow: inset -3px 0 0 rgba(244, 199, 107, 0.5);
}

.messages-area {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 0.8rem;
  overflow: auto;
  border: 1px solid var(--line);
  border-radius: 28px;
  background: rgba(255, 255, 255, 0.03);
  padding: 1rem;
}

.message-row {
  display: flex;
  justify-content: flex-start;
}

.message-row--own {
  justify-content: flex-end;
}

.message-bubble {
  max-width: min(78%, 620px);
}

.message-bubble--own {
  background: linear-gradient(135deg, rgba(244, 199, 107, 0.16), rgba(244, 199, 107, 0.08));
}

.message-bubble strong {
  display: block;
  margin-bottom: 0.35rem;
}

.message-bubble p {
  margin: 0;
  line-height: 1.55;
}

.message-image {
  margin-top: 0.8rem;
  max-height: 240px;
  width: 100%;
  border-radius: 18px;
  object-fit: cover;
}

.voice-card {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  margin-top: 0.6rem;
}

.composer-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 0.7rem;
}

.file-button {
  position: relative;
  overflow: hidden;
}

.empty-state {
  align-items: center;
  justify-content: center;
  min-height: 180px;
  text-align: center;
}

.coverage-item {
  display: flex;
  gap: 0.7rem;
  animation: slide-in 0.6s ease-out;
  transition: all 0.3s ease;
}

.coverage-item:hover {
  transform: translateX(8px);
}

.user-cell {
  display: flex;
  align-items: center;
  gap: 0.8rem;
}

.actions-inline--center {
  justify-content: center;
}

.actions-inline--wrap {
  flex-wrap: wrap;
}

.coverage-item span {
  color: var(--green);
  font-weight: 800;
}

.danger-zone {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  border: 1px dashed rgba(251, 113, 133, 0.38);
  border-radius: 24px;
  padding: 1rem;
  background: rgba(251, 113, 133, 0.08);
}

.form-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.field--full {
  grid-column: 1 / -1;
}

@media (max-width: 1180px) {
  .hero-section,
  .dashboard-shell,
  .auth-layout-grid,
  .chat-layout,
  .landing-grid,
  .kpi-grid,
  .mini-stats,
  .form-grid,
  .dashboard-grid,
  .metric-bars,
  .hero-showcase,
  .premium-strip,
  .landing-grid--featured {
    grid-template-columns: 1fr;
  }

  .chat-sidebar,
  .chat-main {
    min-height: auto;
  }
}

@media (max-width: 780px) {
  .site-shell {
    padding: 0.85rem;
  }

  .site-header,
  .hero-section,
  .panel,
  .auth-card,
  .auth-side-card,
  .profile-card {
    border-radius: 24px;
  }

  .site-header,
  .panel-header,
  .entity-card__header,
  .shop-meta,
  .checkout-line,
  .list-row,
  .cart-row {
    flex-direction: column;
  }

  .site-nav {
    justify-content: flex-start;
  }

  .message-bubble {
    max-width: 100%;
  }
}
